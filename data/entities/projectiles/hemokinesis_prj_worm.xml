<Entity name="$projectile_default" tags="resist_repulsion,projectile_heal" >

	<Base file="data/entities/base_projectile.xml" >
    <VelocityComponent
      gravity_y="-10"
      air_friction="0.1"
	  mass="0.04"
	  >
    </VelocityComponent>
	</Base>

	<HomingComponent
		target_tag="de_dark_curse"
		homing_targeting_coeff="9"
		detect_distance="216"
		homing_velocity_multiplier="1.0"
		>
	</HomingComponent>

  <ProjectileComponent 
    _enabled="1" 
    lob_min="0.8"
    lob_max="1.0"
    speed_min="100"
    speed_max="100"
    direction_random_rad="0.9"
    on_death_explode="0"
    on_death_gfx_leave_sprite="0" 
    on_lifetime_out_explode="0"
    explosion_dont_damage_shooter="1" 
    on_collision_die="1"
	collide_with_world="0"
	collide_with_tag="de_dark_curse"
    lifetime="125"
    damage="0.72"
    velocity_sets_scale="1"
    lifetime_randomness="7"
    ragdoll_force_multiplier="0.04"
    hit_particle_force_multiplier="5.5 "
    camera_shake_when_shot="15.0" 
	muzzle_flash_file="data/entities/particles/muzzle_flashes/muzzle_flash_launcher.xml"
    shoot_light_flash_r="200"
    shoot_light_flash_g="188"
    shoot_light_flash_b="0"
    shoot_light_flash_radius="90"
	knockback_force="1.0"
	physics_impulse_coeff="3000"
	>
    <config_explosion
      never_cache="1" 
      camera_shake="20" 
      explosion_radius="7" 
      explosion_sprite="data/particles/explosion_032.xml"
      explosion_sprite_lifetime="0"
      load_this_entity="data/entities/particles/particle_explosion/main_small.xml"
      create_cell_probability="10" 
      cell_explosion_power_ragdoll_coeff="0.5"
      hole_destroy_liquid="0"
      explosion_sprite_additive="1"
      hole_enabled="1" 
      ray_energy="900000"
      damage="0.2"
      particle_effect="1" 
      damage_mortals="1"
      physics_explosion_power.min="1.0" 
      physics_explosion_power.max="1.1"
      physics_throw_enabled="1"
      shake_vegetation="1" 
      sparks_count_max="4" 
      sparks_count_min="3" 
      sparks_enabled="1" 
      stains_enabled="1" 
      stains_radius="9"
      audio_event_name="explosions/magic_rocket_small" >
    </config_explosion>
  </ProjectileComponent>
  
  	<!-- dense emitter -->
	<ParticleEmitterComponent 
		emitted_material_name="blood_worm"
		offset.x="0"
		offset.y="0"
		x_pos_offset_min="0"
		x_pos_offset_max="0"
		y_pos_offset_min="0"
		y_pos_offset_max="0"
		x_vel_min="0"
		x_vel_max="0"
		y_vel_min="0"
		y_vel_max="0"
		gravity.y="0.0"
		count_min="1"
		count_max="2"
		lifetime_min="0.1"
		lifetime_max="0.2"
		is_trail="1"
		trail_gap="1.2"
		render_on_grid="1"
		fade_based_on_lifetime="1"
		airflow_force="17.5"
		airflow_time="1.401"
		airflow_scale="0.05"
		emission_interval_min_frames="1"
		emission_interval_max_frames="2"
		emit_cosmetic_particles="1"
		create_real_particles="0"
		is_emitting="1" >
	</ParticleEmitterComponent>
	
  	<!-- sparse emitter -->
	<ParticleEmitterComponent 
		emitted_material_name="blood_worm"
		offset.x="0"
		offset.y="0"
		x_pos_offset_min="0"
		x_pos_offset_max="0"
		y_pos_offset_min="0"
		y_pos_offset_max="0"
		x_vel_min="20"
		x_vel_max="40"
		y_vel_min="0"
		y_vel_max="0"
		gravity.y="0.0"
		count_min="1"
		count_max="1"
		lifetime_min="0.2"
		lifetime_max="0.6"
		is_trail="0"
		trail_gap="8.0"
		render_on_grid="1"
		fade_based_on_lifetime="1"
		airflow_force="1.8"
		airflow_time="0.401"
		airflow_scale="0.05"
		emission_interval_min_frames="1"
		emission_interval_max_frames="15"
		emit_cosmetic_particles="1"
		create_real_particles="0"
		is_emitting="1" >
	</ParticleEmitterComponent>
	
  	<!-- very sparse emitter -->
	<ParticleEmitterComponent 
		emitted_material_name="blood_worm"
		offset.x="0"
		offset.y="0"
		x_pos_offset_min="0"
		x_pos_offset_max="0"
		y_pos_offset_min="0"
		y_pos_offset_max="0"
		x_vel_min="10"
		x_vel_max="20"
		y_vel_min="0"
		y_vel_max="0"
		gravity.y="0.0"
		count_min="1"
		count_max="1"
		lifetime_min="0.6"
		lifetime_max="1.2"
		is_trail="0"
		trail_gap="8.0"
		render_on_grid="1"
		fade_based_on_lifetime="1"
		airflow_force="0.9"
		airflow_time="0.5"
		airflow_scale="0.05"
		emission_interval_min_frames="10"
		emission_interval_max_frames="30"
		emit_cosmetic_particles="1"
		create_real_particles="0"
		is_emitting="1" >
	</ParticleEmitterComponent>

	<LightComponent 
    _enabled="1" 
	r="200"
	g="188"
	b="0"
    radius="12" >
  </LightComponent>

  <SpriteComponent 
		alpha="0.75"
		image_file="data/particles/fog_of_war_hole.xml"
		smooth_filtering="1"
		fog_of_war_hole="1" >
	</SpriteComponent>
  
	<VariableStorageComponent
		name="projectile_file"
		value_string="data/entities/projectiles/hemokinesis_prj_worm.xml"
		>
	</VariableStorageComponent>

</Entity>