		sparks_enabled="0"  
		material_sparks_enabled="1"
		material_sparks_count_max="2"
		material_sparks_count_min="0" 
		light_enabled="0" 
		stains_enabled="0"
		stains_radius="3"
		audio_event_name="player_projectiles/torch/enable" >
