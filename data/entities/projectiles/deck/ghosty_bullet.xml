        effect_hit="LOAD_UNIQUE_CHILD_ENTITY"
        value_string="data/entities/misc/effect_disintegrated_air.xml" >
	</HitEffectComponent>

	<AreaDamageComponent
		aabb_min.x="-12" 
		aabb_min.y="-12" 
		aabb_max.x="12" 
		aabb_max.y="12" 
		damage_per_frame="0.08"
		update_every_n_frame="1"
		entities_with_tag="boss_ghost_helper"
		damage_type="NONE"
		death_cause="$dGHOSTY_BULLET"
	></AreaDamageComponent>

	<LightComponent 
		_enabled="1" 
		r="40"
		g="190"
		b="255"
		radius="15" >
	</LightComponent>

	<AudioComponent
		file="data/audio/Desktop/projectiles.bank"
		event_root="player_projectiles/bullet_burst_of_air">
	</AudioComponent>
  
	<VariableStorageComponent
		name="projectile_file"
		value_string="data/entities/projectiles/deck/ghosty_bullet.xml"
