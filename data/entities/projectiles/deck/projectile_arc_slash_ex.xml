<Entity name="$projectile_default" tags="resist_repulsion,projectile_player" >

	<Base file="data/entities/base_projectile.xml" >
		<VelocityComponent
			air_friction="-30"
			gravity_y="0"
			mass="0.08"
			>
		</VelocityComponent>
	</Base>

  <ProjectileComponent 
    _enabled="1" 
    lob_min="5"
    lob_max="5"
    speed_min="100"
    speed_max="100"
    friction="-30"
    direction_random_rad="0.07"
    on_death_explode="0"
    on_death_gfx_leave_sprite="0" 
    on_lifetime_out_explode="1"
    explosion_dont_damage_shooter="1" 
    on_collision_die="0"
    lifetime="9"
    damage="0.0"
    velocity_sets_scale="1"
    velocity_updates_animation="1"
    lifetime_randomness="0"
    ragdoll_force_multiplier="0.05"
    hit_particle_force_multiplier="0.25 "
    camera_shake_when_shot="0.1"
    muzzle_flash_file="data/entities/particles/muzzle_flashes/muzzle_flash_magic_launcher.xml"
    shoot_light_flash_r="120"
    shoot_light_flash_g="235"
    shoot_light_flash_b="90"
    shoot_light_flash_radius="40" 
	  knockback_force="3.0"
	  physics_impulse_coeff="3000"
	><damage_by_type
		melee="0.54"
    slice="0.36"
	></damage_by_type>
    <config_explosion
      never_cache="1" 
      damage="0"
      camera_shake="2.0" 
      explosion_radius="9"
      explosion_sprite="" 
      explosion_sprite_lifetime="0" 
      create_cell_probability="0"
	    explosion_sprite_additive="1"
      hole_destroy_liquid="0" 
      hole_enabled="1" 
      ray_energy="300000"
      particle_effect="0" 
      damage_mortals="1"
	    physics_explosion_power.min="0.1" 
      physics_explosion_power.max="0.3" 
      physics_throw_enabled="1" 
      shake_vegetation="1" 
      sparks_count_max="1" 
      sparks_count_min="3" 
      sparks_enabled="0" 
      material_sparks_enabled="1"
      material_sparks_count_max="3"
      material_sparks_count_min="0" 
      light_enabled="0" 
      stains_enabled="0"
      stains_radius="1"
	    spark_material="spark_blue"
      audio_enabled="0"
	  >
    </config_explosion>
  </ProjectileComponent>

  <LifetimeComponent
			lifetime="40" >
	</LifetimeComponent>
  
  <SpriteComponent 
    _enabled="1" 
    alpha="0.9" 
    has_special_scale="1"
	  special_scale_x="0.8"
	  special_scale_y="0.6"
    image_file="data/projectiles_gfx/katana_arc_slash.xml" 
    next_rect_animation="" 
    offset_x="0" 
    offset_y="0" 
    rect_animation="fireball"
     >
  </SpriteComponent>

  <LuaComponent
		_enabled="1" 
		remove_after_executed="0"
		script_source_file="data/scripts/projectiles/slash_spin.lua"
		execute_every_n_frame="1"
		>
	</LuaComponent>
	
	<LightComponent 
    _enabled="1" 
    radius="30" >
  	</LightComponent>

  	<AudioComponent
        file="data/audio/Desktop/projectiles.bank"
        event_root="player_projectiles/bullet_disc">
    </AudioComponent>
  
    <AudioLoopComponent
        file="data/audio/Desktop/projectiles.bank"
        event_name="player_projectiles/bullet_disc/loop"
        set_speed_parameter="1"
        auto_play="1">
    </AudioLoopComponent>
  
	<VariableStorageComponent
		name="projectile_file"
		value_string="data/entities/projectiles/deck/katana_arc_slash.xml"
		>
	</VariableStorageComponent>

</Entity>

