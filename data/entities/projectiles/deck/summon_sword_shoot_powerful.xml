<Entity 
  name="$projectile_default" tags="resist_repulsion,projectile_heal,thunder"
   >

	<Base file="data/entities/base_projectile.xml" >
		<VelocityComponent
    		gravity_y="0"
			air_friction="-8"
			terminal_velocity="16384"
			liquid_drag="0"
			>
    	</VelocityComponent> 
	</Base>

  <ProjectileComponent 
    _enabled="1" 
	lob_min="0.8"
  	lob_max="1.0"
  	speed_min="400"
  	speed_max="400"
    die_on_low_velocity="0"
    on_death_explode="1"
    on_death_gfx_leave_sprite="0" 
    on_lifetime_out_explode="1"
	explosion_dont_damage_shooter="1"
    damage="1.44"
    on_collision_die="0"
	collide_with_world="0"
    lifetime="90" 
	velocity_sets_rotation="1"
    velocity_updates_animation="1"
    velocity_sets_scale="0">
	<damage_by_type
		holy="1.2"
		curse="1.2"
		healing="-0.008"
		>
	</damage_by_type>
    <config_explosion
	  never_cache="1" 
      damage="0.004"
      camera_shake="5.0" 
      explosion_radius="6"
      explosion_sprite="" 
      explosion_sprite_lifetime="0" 
      create_cell_probability="0"
      hole_destroy_liquid="0" 
      hole_enabled="1" 
      ray_energy="550000"
	  max_durability_to_destroy="11"
      particle_effect="0" 
      damage_mortals="1"
	  physics_explosion_power.min="0.1"
      physics_explosion_power.max="0.15"
      physics_throw_enabled="1" 
      shake_vegetation="1" 
      sparks_count_max="3" 
      sparks_count_min="2" 
      sparks_enabled="1" 
      light_enabled="0" 
      stains_enabled="0"
      stains_radius="1"
	  spark_material="plasma_fading_bright"
      audio_enabled="0">
    </config_explosion>
  </ProjectileComponent>

  <SpriteParticleEmitterComponent
		_tags="enabled_in_world,enabled_in_hand,item_identified"
		sprite_file="data/particles/spark_electric.xml"
		delay="0"
		lifetime="0"
		color.r="0.7" color.g="1" color.b="1" color.a="0.9"
		color_change.r="-0.15" color_change.g="0" color_change.b="-0.05" color_change.a="-1"
		velocity.x="0" velocity.y="0"
		gravity.x="0" gravity.y="0"
		velocity_slowdown="0"
		rotation="0"
		angular_velocity="0"
		use_velocity_as_rotation="0"
		scale.x="0.7" scale.y="0.7"
		scale_velocity.x="0" scale_velocity.y="0"
		emission_interval_min_frames="15"
		emission_interval_max_frames="45"
		count_min="1" 
		count_max="3"
		randomize_rotation.min="-3.1415"
		randomize_rotation.max="3.1415"
		randomize_position.min_x="-14"
		randomize_position.max_x="14"
		randomize_position.min_y="-3"
		randomize_position.max_y="3"
		randomize_velocity.min_x="-6"
		randomize_velocity.max_x="6"
		randomize_velocity.min_y="-6"
		randomize_velocity.max_y="6"
		>
	</SpriteParticleEmitterComponent>
  
  <SpriteComponent 
    _enabled="1" 
    alpha="0.6" 
    image_file="data/projectiles_gfx/summon_sword_shoot.xml" 
	has_special_scale="1"
	special_scale_x="1.02"
	special_scale_y="0.82"
    next_rect_animation=""
    rect_animation="" 
	>
  </SpriteComponent>

  <SpriteComponent 
    _enabled="1" 
    alpha="0.6" 
    image_file="data/projectiles_gfx/summon_sword.xml" 
	has_special_scale="1"
	special_scale_x="0.98"
	special_scale_y="0.78"
    next_rect_animation=""
    rect_animation="" 
	>
  </SpriteComponent>

	<AudioComponent
      file="data/audio/Desktop/projectiles.bank"
      event_root="projectiles/laser_wraith">
  </AudioComponent>
  
	<LightComponent 
		_enabled="1"
		radius="80" >
	</LightComponent>

	<SpriteComponent 
		alpha="0.6"
		image_file="data/particles/fog_of_war_hole_128.xml"
		smooth_filtering="1"
		fog_of_war_hole="1" >
	</SpriteComponent>

	<HitEffectComponent 
        effect_hit="LOAD_CHILD_ENTITY"
        value_string="data/entities/misc/hitfx_sin_effect.xml" >
	</HitEffectComponent >

	<VariableStorageComponent
		name="projectile_file"
		value_string="data/entities/projectiles/deck/summon_sword_shoot_powerful.xml"
		>
	</VariableStorageComponent>

  </Entity>