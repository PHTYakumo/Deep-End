<Entity name="$projectile_default" tags="resist_repulsion,projectile_player" >

	<Base file="data/entities/base_projectile.xml" >
    <VelocityComponent
      gravity_y="0"
      air_friction="-7"
      terminal_velocity="500"
	    mass="0.01"
	  >
    </VelocityComponent>
	</Base>

  <ProjectileComponent 
    _enabled="1" 
    lob_min="0.5"
    lob_max="0.7"
    speed_min="300"
    speed_max="300"
    friction="1"
    direction_random_rad="0"
    on_death_explode="0"
    on_death_gfx_leave_sprite="0" 
    on_lifetime_out_explode="0"
    explosion_dont_damage_shooter="1"
    collide_with_world="0"
    on_collision_die="0"
    lifetime="55"
    damage="0.0"
    velocity_sets_scale="0"
    lifetime_randomness="0"
    ragdoll_force_multiplier="0.009"
    hit_particle_force_multiplier="0.9"
    shoot_light_flash_r="128"
    shoot_light_flash_g="128"
    shoot_light_flash_b="128"
    shoot_light_flash_radius="48"
	  knockback_force="0.3"
    physics_impulse_coeff="100000"
	  ><damage_by_type
			drill="0.012"
			melee="0.012"
		></damage_by_type
    ><config_explosion
      never_cache="1" 
      damage="0"
      camera_shake="0.0" 
      explosion_radius="24" 
      explosion_sprite="" 
      explosion_sprite_lifetime="0" 
      create_cell_probability="0" 
      hole_destroy_liquid="0" 
      hole_enabled="0" 
      ray_energy="0"
      particle_effect="0" 
      damage_mortals="0"
	    physics_explosion_power.min="0" 
      physics_explosion_power.max="0" 
      physics_throw_enabled="0" 
      shake_vegetation="1" 
      sparks_count_max="0" 
      sparks_count_min="0" 
      sparks_enabled="0"  
      material_sparks_enabled="0"
      material_sparks_count_max="0"
      material_sparks_count_min="0" 
      light_enabled="0" 
      stains_enabled="0"
      stains_radius="0"
    ></config_explosion>
  </ProjectileComponent>
  
  <SpriteComponent 
    _enabled="0" 
    alpha="1" 
    image_file="data/particles/thrust_ray.xml" 
    next_rect_animation=""
    rect_animation="" 
     >
  </SpriteComponent>

  <SpriteParticleEmitterComponent
    _enabled="0" 
		sprite_file="data/particles/thrust_ray.xml"
		delay="0"
		lifetime="0.04"
		color.r="1" color.g="1" color.b="1" color.a="0.7"
		color_change.r="0" color_change.g="0" color_change.b="0" color_change.a="-0.7"
		velocity.x="0" velocity.y="0"
		gravity.x="0" gravity.y="0"
		velocity_slowdown="0"
		rotation="0"
		angular_velocity="0"
		use_rotation_from_velocity_component="1"
		scale.x="1.25" scale.y="0.75"
		scale_velocity.x="0.0" scale_velocity.y="0.0"
		emission_interval_min_frames="2"
		emission_interval_max_frames="2"
		count_min="1" 
		count_max="4"
		randomize_rotation.min="0"
		randomize_rotation.max="0"
		randomize_position.min_x="-36"
		randomize_position.max_x="0"
		randomize_position.min_y="-3"
		randomize_position.max_y="3"
		randomize_velocity.min_x="0"
		randomize_velocity.max_x="0"
		randomize_velocity.min_y="0"
		randomize_velocity.max_y="0"
    entity_velocity_multiplier="0.55"
		>
	</SpriteParticleEmitterComponent>
  
	<LightComponent 
    _enabled="0" 
    radius="20" >
  </LightComponent>

  <MagicConvertMaterialComponent
    fan_the_flames="10"
    from_material=""
    to_material=""
    steps_per_frame="20"
    loop="1"
    is_circle="1"
    radius="4" >
  </MagicConvertMaterialComponent>

  <LuaComponent
		script_source_file="data/scripts/projectiles/thrust_audio.lua" 
		execute_every_n_frame="4" >
	</LuaComponent>

  <LuaComponent
		script_source_file="data/scripts/projectiles/thrust_phase.lua" 
		execute_every_n_frame="1" >
	</LuaComponent>

	<VariableStorageComponent
		name="sx"
		value_float="0">
	</VariableStorageComponent>

	<VariableStorageComponent
		name="sy"
		value_float="0">
	</VariableStorageComponent>

	<VariableStorageComponent
		name="angle"
		value_float="0" >
	</VariableStorageComponent>
  
	<VariableStorageComponent
		name="projectile_file"
		value_string="data/entities/projectiles/deck/thrust.xml" >
	</VariableStorageComponent>

</Entity>

