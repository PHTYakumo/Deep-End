<Entity name="$projectile_default" >
	<Base file="data/entities/base_projectile.xml" >
		<VelocityComponent
			gravity_y="0"
			air_friction="0"
			terminal_velocity="1"
			>
		</VelocityComponent> 
	</Base>

	<ProjectileComponent 
		_enabled="1" 
		lob_min="0.8"
		lob_max="1.0"
		speed_min="0"
		speed_max="0"
		die_on_low_velocity="0"
		on_death_explode="0"
		on_death_gfx_leave_sprite="0" 
		on_lifetime_out_explode="0"
		explosion_dont_damage_shooter="1"
		damage="0.0"
		on_collision_die="0"
		collide_with_world="0"
		damage_every_x_frames="10"
		collide_with_shooter_frames="60"
		friendly_fire="1"
		lifetime="54" >
	</ProjectileComponent>

	<LifetimeComponent lifetime="240" />

	<GameAreaEffectComponent radius="20.5" />

	<SpriteComponent 
		_enabled="1" 
		alpha="1" 
		image_file="data/projectiles_gfx/target_order.xml" 
		next_rect_animation="" 
		rect_animation="fireball"
		has_special_scale="1"
		special_scale_x="1.1"
		special_scale_y="1.1" 
		additive="1"
		emissive="1"
		>
	</SpriteComponent>
	
	<LuaComponent
		_enabled="1" 
		remove_after_executed="0"
		script_source_file="data/scripts/projectiles/order.lua"
		execute_every_n_frame="5"
		>
	</LuaComponent>

	<LuaComponent
		_enabled="1" 
		remove_after_executed="0"
		script_source_file="data/scripts/projectiles/order_aim.lua"
		execute_every_n_frame="1"
		>
	</LuaComponent>

	<LuaComponent
		_enabled="1" 
		execute_on_removed="1"
		script_source_file="data/scripts/projectiles/order_fade.lua"
		execute_every_n_frame="-1"
		>
	</LuaComponent>

	<AudioLoopComponent
		file="data/audio/Desktop/projectiles.bank"
		event_name="player_projectiles/meteor/loop"
		auto_play="1">
	</AudioLoopComponent>

	<AudioComponent
		file="data/audio/Desktop/projectiles.bank"
		event_root="player_projectiles/megalaser">
	</AudioComponent>

	<HitEffectComponent 
        effect_hit="LOAD_UNIQUE_CHILD_ENTITY"
        value_string="data/entities/misc/effect_movement_slower_ui.xml" >
	</HitEffectComponent >
	
	<VariableStorageComponent
		name="projectile_file"
		value_string="data/entities/projectiles/deck/order_projectile.xml"
		>
	</VariableStorageComponent>
</Entity>