<Entity name="$projectile_default" tags="resist_repulsion,projectile_player,projectile_boss_spirit" >

	<Base file="data/entities/base_projectile.xml" >
		<VelocityComponent
			gravity_y="0"
			air_friction="-0.3" 
			mass="0.15"
			>
		</VelocityComponent>
	</Base>

  <ProjectileComponent 
    _enabled="1" 
    lob_min="0.8"
    lob_max="1.1"
    speed_min="500"
    speed_max="600"
    direction_random_rad="0.009"
    on_death_explode="0"
    on_death_gfx_leave_sprite="0" 
    on_lifetime_out_explode="0"
	die_on_low_velocity="0"
    explosion_dont_damage_shooter="0"
    on_collision_die="1"
    ragdoll_force_multiplier="0.03"
    lifetime="21"
    ground_penetration_coeff="6"
    velocity_sets_scale="1"
    camera_shake_when_shot="0"
    shoot_light_flash_radius="64"
    hit_particle_force_multiplier="0.1"
    create_shell_casing="0"
    bounces_left="0"
	collide_with_shooter_frames="666"
	penetrate_entities="1"
	friendly_fire="0"
    damage="0.0"	
	muzzle_flash_file="data/entities/particles/muzzle_flashes/muzzle_flash_large.xml"
	shoot_light_flash_radius="140"
	shoot_light_flash_r="155"
    shoot_light_flash_g="235"
    shoot_light_flash_b="255"
	knockback_force="0.7"
	><damage_by_type 
        curse="0.34"
    ></damage_by_type>
    <config_explosion
      never_cache="1" 
      damage="0.4"
      camera_shake="0" 
      explosion_radius="3" 
      explosion_sprite="data/particles/explosion_032.xml" 
      explosion_sprite_lifetime="0" 
      create_cell_probability="0" 
      hole_destroy_liquid="0" 
      hole_enabled="1" 
      hole_image="data/temp/explosion_hole.png"
	  explosion_sprite_additive="1"
      ray_energy="100000"
      particle_effect="0"
	  physics_explosion_power.min="0"  
      physics_explosion_power.max="0"  
      physics_throw_enabled="0" 
      shake_vegetation="1" 
      sparks_count_min="7"
      sparks_count_max="13"
      sparks_enabled="1"
	  spark_material="blood_fading"
      light_enabled="1" 
	  light_fade_time="1"
	  light_r="40"
	  light_g="120"
	  light_b="180"
      stains_enabled="1"
      stains_radius="1">
    </config_explosion>
  </ProjectileComponent>
  
  <SpriteComponent 
    _enabled="1" 
    alpha="1" 
	emissive="1"
	z_index="-1"
	has_special_scale="1"
	special_scale_x="0.96"
	special_scale_y="0.64"
    image_file="data/projectiles_gfx/dark_sword.xml" 
    next_rect_animation=""
    rect_animation="" 
	smooth_filtering="1"
     >
  </SpriteComponent>
	
	<SpriteParticleEmitterComponent
		sprite_file="data/particles/dark_sword.xml"
		delay="0"
		lifetime="0.1"
		color.r="1" color.g="1" color.b="1" color.a="0.25"
		color_change.r="0" color_change.g="0" color_change.b="0" color_change.a="-1"
		velocity.x="0" velocity.y="0"
		gravity.x="0" gravity.y="0"
		velocity_slowdown="1"
		rotation="0"
		angular_velocity="0"
		use_velocity_as_rotation="1"
		scale.x="0.64" scale.y="0.96"
		scale_velocity.x="0" scale_velocity.y="0"
		emission_interval_min_frames="5"
		emission_interval_max_frames="5"
		count_min="1" 
		count_max="1"
		randomize_rotation.min="0"
		randomize_rotation.max="0"
		randomize_position.min_x="-0.7"
		randomize_position.max_x="-0.3"
		randomize_position.min_y="-0.2"
		randomize_position.max_y="0.2"
		randomize_velocity.min_x="0"
		randomize_velocity.max_x="0"
		randomize_velocity.min_y="0"
		randomize_velocity.max_y="0"
		entity_velocity_multiplier="0.08"
		>
	</SpriteParticleEmitterComponent>
	
	<LightComponent 
    _enabled="1" 
    radius="2"
	r="150"
	g="150"
	b="150"
	>
  </LightComponent>

  	<HitEffectComponent 
        effect_hit="LOAD_UNIQUE_CHILD_ENTITY"
        value_string="data/entities/misc/effect_dark_sword.xml" >
	</HitEffectComponent >

	<LuaComponent
		execute_on_removed="1"
		execute_every_n_frame="-1"
		script_source_file="data/scripts/projectiles/dark_sword_curse.lua"
		remove_after_executed="0">
  	</LuaComponent>

  <AudioComponent
      file="data/audio/Desktop/projectiles.bank"
      event_root="player_projectiles/bullet_disc_big">
  </AudioComponent>
  
	<VariableStorageComponent
		name="projectile_file"
		value_string="data/entities/projectiles/deck/dark_sword.xml"
		>
	</VariableStorageComponent>

</Entity>

