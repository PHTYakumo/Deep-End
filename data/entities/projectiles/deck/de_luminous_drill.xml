<Entity name="$projectile_default" tags="projectile_player" >

	<Base file="data/entities/base_projectile.xml" >
		<VelocityComponent
      gravity_y="0"
			mass="1.65"
      terminal_velocity="1600"
			>
		</VelocityComponent>
	</Base>

  <ProjectileComponent 
    _enabled="1" 
    lob_min="0.8"
    lob_max="1.0"
    speed_min="660"
    speed_max="660"
    friction="0.0"
    direction_random_rad="0"
    on_death_explode="0"
    on_death_gfx_leave_sprite="0" 
    on_lifetime_out_explode="0"
    ground_collision_fx="1"
    on_collision_die="1"
    penetrate_entities="1"
    lifetime="4"
    damage="0.1"
    velocity_sets_scale="0"
    lifetime_randomness="0"
    ragdoll_force_multiplier="0.01"
    hit_particle_force_multiplier="0.25"
	  ground_penetration_coeff="3.9"
	  ground_penetration_max_durability_to_destroy="14"
    ><damage_by_type
		drill="0.4"
		>
	</damage_by_type>
  </ProjectileComponent>

  <LifetimeComponent
			lifetime="11" >
	</LifetimeComponent>

  <HitEffectComponent 
      effect_hit="LOAD_UNIQUE_CHILD_ENTITY"
      value_string="data/entities/misc/effect_disintegrated_air.xml" >
	</HitEffectComponent >
  
  <ParticleEmitterComponent 
    emitted_material_name="spark_green"
    delay_frames="1"
    count_min="40"
    count_max="60"
    x_pos_offset_min="2"
    x_pos_offset_max="10"
    offset.x="0"
    offset.y="0"
    lifetime_min="0.03"
    lifetime_max="0.07"
    create_real_particles="0"
    emit_cosmetic_particles="1"
    emission_interval_min_frames="1"
    emission_interval_max_frames="1"
    attractor_force="0.9"
    airflow_force="0.8"
    airflow_time="0.01"
    airflow_scale="0.5"
    is_trail="1"
    is_emitting="1" >
  </ParticleEmitterComponent>

  <LuaComponent
		script_source_file="data/scripts/projectiles/vel_set_emitter.lua"
		execute_every_n_frame="1"
		remove_after_executed="0">
	</LuaComponent>

  <LightComponent 
		_enabled="1"
		radius="40">
	</LightComponent>

	<SpriteComponent 
		alpha="0.6"
		image_file="data/particles/fog_of_war_hole_128.xml"
		smooth_filtering="1"
		fog_of_war_hole="1">
	</SpriteComponent>
  
  <AudioComponent
      file="data/audio/Desktop/projectiles.bank"
      event_root="player_projectiles/luminous_drill">
  </AudioComponent>
  
  <VariableStorageComponent
		name="projectile_file"
		value_string="data/entities/projectiles/deck/de_luminous_drill.xml">
	</VariableStorageComponent>
</Entity>

