<Entity name="$projectile_default" tags="resist_repulsion,teleportable_NOT,thunder,projectile_heal" >

  <VelocityComponent
		gravity_y="120"
		air_friction="0.0"
		mass="0.07"
		affect_physics_bodies="1" >
	</VelocityComponent>

  <ProjectileComponent
    lob_min="0.5"
    lob_max="0.7"
    speed_min="800"
    speed_max="800"
    friction="0.0"
    direction_random_rad="0"
    on_death_explode="1"
    on_death_gfx_leave_sprite="0" 
    on_lifetime_out_explode="1"
    explosion_dont_damage_shooter="1"
    dont_collide_with_tag="player_unit"
    collide_with_world="0"
    lifetime="2"
    damage="0.0"
    velocity_sets_scale="1"
    lifetime_randomness="0"
    ragdoll_force_multiplier="0.04"
    hit_particle_force_multiplier="0.04"
	  muzzle_flash_file="data/entities/particles/muzzle_flashes/muzzle_flash_laser_green.xml"
    shoot_light_flash_r="120"
    shoot_light_flash_g="255"
    shoot_light_flash_b="80"
    shoot_light_flash_radius="12" 
	  knockback_force="14.0"
    physics_impulse_coeff="1500"
    ><damage_by_type 
    melee="0.2"
    healing="-0.002"
    ></damage_by_type>
    <config_explosion
    never_cache="1" 
    damage="0"
    camera_shake="0.5" 
    explosion_radius="2" 
    explosion_sprite="" 
    explosion_sprite_lifetime="0" 
    create_cell_probability="0" 
    hole_destroy_liquid="0"
    explosion_sprite_additive="1"
    hole_enabled="1" 
    ray_energy="400000"
    max_durability_to_destroy="8"
    particle_effect="0" 
    damage_mortals="1"
    physics_explosion_power.min="0.02" 
    physics_explosion_power.max="0.1" 
    physics_throw_enabled="1"  
    shake_vegetation="1" 
    sparks_count_max="20" 
    sparks_count_min="7" 
    sparks_enabled="0"  
    material_sparks_enabled="1"
    material_sparks_count_max="2"
    material_sparks_count_min="0" 
    light_enabled="1" 
    light_r="40"
    light_g="90"
    light_b="10"
    stains_enabled="1"
    stains_radius="3"
    >
    </config_explosion>
  </ProjectileComponent>

  <AreaDamageComponent
		aabb_min.x="-16" 
		aabb_min.y="-16" 
		aabb_max.x="12" 
		aabb_max.y="12" 
		damage_per_frame="0.28"
		update_every_n_frame="1"
		entities_with_tag="enemy"
		death_cause="$DASH"
		damage_type="DAMAGE_BITE"
		>
	</AreaDamageComponent>
	
  <AudioComponent
      file="data/audio/Desktop/projectiles.bank"
      event_root="player_projectiles/bullet_burst_of_air">
  </AudioComponent>
  
	<VariableStorageComponent
		name="projectile_file"
		value_string="data/entities/projectiles/deck/de_hook.xml"
		>
	</VariableStorageComponent>
	
	 <LuaComponent
    remove_after_executed="0"
		script_source_file="data/scripts/projectiles/hook_dash.lua"
		execute_every_n_frame="1"
		>
	  </LuaComponent>

</Entity>

