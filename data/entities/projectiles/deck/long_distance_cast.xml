			mass="0.1"
			>
		</VelocityComponent>
	</Base>

  <ProjectileComponent 
    _enabled="1" 
    lob_min="0.8"
    lob_max="1.0"
    speed_min="1800"
    speed_max="1800"
    friction="0.0"
    direction_random_rad="0"
    on_death_explode="0"
    on_death_gfx_leave_sprite="0" 
    on_lifetime_out_explode="0"
    ground_collision_fx="1"
    on_collision_die="0"
    lifetime="4"
    damage="0"
    collide_with_tag="de_dark_curse"
    velocity_sets_scale="0"
    lifetime_randomness="0"
    ragdoll_force_multiplier="0.01"
    hit_particle_force_multiplier="0.01"
	  penetrate_entities="1"
	  penetrate_world="1"
    ground_penetration_coeff="1"
    >
	<config_explosion
      null_damage="1"
      never_cache="1" 
      damage="0.0"
      camera_shake="0.2" 
      explosion_radius="2" 
      explosion_sprite="data/particles/explosion_008_pink.xml" 
      explosion_sprite_lifetime="0" 
      create_cell_probability="0" 
      hole_destroy_liquid="0" 
      hole_enabled="0" 
      ray_energy="10"
      max_durability_to_destroy="4"
      particle_effect="0" 
      damage_mortals="0"
	    physics_explosion_power.min="0.1"
      physics_explosion_power.max="0.2" 
      physics_throw_enabled="1" 
      shake_vegetation="1" 
      sparks_count_max="5" 
      sparks_count_min="2" 
      sparks_enabled="0"  
	    spark_material="plasma_fading_pink"
      light_enabled="0" 
      stains_enabled="0"
      stains_radius="3" 
	    audio_enabled="0"
	  >
    </config_explosion>
  </ProjectileComponent>

  <LifetimeComponent
			lifetime="60" >
	</LifetimeComponent>

  <ParticleEmitterComponent 
    emitted_material_name="spark_purple_bright"
    attractor_force="100"
    count_min="20"
    count_max="20"
    x_vel_min="-5"
    x_vel_max="5"
    y_vel_min="-2"
    y_vel_max="2"
    x_pos_offset_min="0"
    x_pos_offset_max="0"
    offset.x="0"
    offset.y="0"
    lifetime_min="0.05"
    lifetime_max="0.05"
    create_real_particles="0"
    emit_cosmetic_particles="1"
    emission_interval_min_frames="1"
    emission_interval_max_frames="1"
    airflow_time="0.05"
    airflow_scale="0.2"
	  is_trail="1"
    is_emitting="1" >
  </ParticleEmitterComponent>
  
  <AudioComponent
      file="data/audio/Desktop/projectiles.bank"
      event_root="player_projectiles/long_distance_cast">
  </AudioComponent>
</Entity>

