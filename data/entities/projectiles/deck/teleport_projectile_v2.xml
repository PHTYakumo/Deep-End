<Entity name="$projectile_default" tags="projectile_player,resist_repulsion,thunder" >

	<Base file="data/entities/base_projectile.xml" >
		<VelocityComponent
		  gravity_y="20"
		  air_friction="37.0"
		  mass="0.04"
      terminal_velocity="16384"
		  >
		</VelocityComponent>
	</Base>

  <TeleportProjectileComponent
    min_distance_from_wall="0">
  </TeleportProjectileComponent>

  <ProjectileComponent 
    _enabled="1" 
    lob_min="0.5"
    lob_max="0.7"
    speed_min="0"
    speed_max="0"
    friction="1"
    direction_random_rad="0.00"
    on_death_explode="1"
    on_death_gfx_leave_sprite="0" 
    on_lifetime_out_explode="1"
    explosion_dont_damage_shooter="1"
    on_collision_die="0"
    on_collision_remove_projectile="0"
    lifetime="8"
    damage="0"
    velocity_sets_scale="1"
    ragdoll_force_multiplier="0.005"
    hit_particle_force_multiplier="0.1"
    create_shell_casing="0"
    muzzle_flash_file="data/entities/particles/muzzle_flashes/muzzle_flash_small.xml"
    shoot_light_flash_radius="120" 
	  shoot_light_flash_r="140"
	  shoot_light_flash_g="210"
	  shoot_light_flash_b="255"
	  never_hit_player="1"
	  ><config_explosion
  	  not_scaled_by_gamefx="1"
      never_cache="1" 
      damage="0.04"
      camera_shake="0.5" 
      explosion_radius="6" 
      explosion_sprite="data/particles/explosion_008.xml" 
      explosion_sprite_lifetime="0" 
      create_cell_probability="0" 
      hole_destroy_liquid="1"
	    explosion_sprite_additive="1"
      hole_enabled="1" 
      ray_energy="360000"
      particle_effect="0" 
      damage_mortals="1"
	    physics_explosion_power.min="0" 
      physics_explosion_power.max="0" 
      physics_throw_enabled="0" 
      shake_vegetation="1" 
      sparks_count_max="20" 
      sparks_count_min="7" 
      sparks_enabled="0"  
      material_sparks_enabled="1"
      material_sparks_count_max="2"
      material_sparks_count_min="0" 
      light_enabled="0" 
      stains_enabled="0"
      stains_radius="3" 
	    audio_enabled="0" >
    </config_explosion>
  </ProjectileComponent>
  
  <SpriteComponent 
    _enabled="1" 
    alpha="1" 
    image_file="" 
    next_rect_animation=""
    rect_animation=""
     >
  </SpriteComponent>
  
  <ParticleEmitterComponent 
    emitted_material_name="spark_purple_bright"
	gravity.y="0.0"
    offset.x="0"
    offset.y="0"
    count_min="2"
    count_max="5"
	x_pos_offset_min="0"
    y_pos_offset_min="0"
    x_pos_offset_max="0"
    y_pos_offset_max="0"
    x_vel_min="0"
    x_vel_max="0"
    y_vel_min="0"
    y_vel_max="0"
    lifetime_min="0.4"
    lifetime_max="1.8"
	fade_based_on_lifetime="1"
	airflow_force="4.0"
	airflow_time="0.10"
	airflow_scale="10.0"
	render_on_grid="1"
	emit_real_particles="0"
    emit_cosmetic_particles="1"
    emission_interval_min_frames="2"
    emission_interval_max_frames="3"
	area_circle_radius.max="12"
	area_circle_radius.min="8"
	velocity_always_away_from_center="-80"
    is_emitting="1" >
  </ParticleEmitterComponent>
  
  <ParticleEmitterComponent 
    emitted_material_name="spark_yellow"
	gravity.y="0.0"
    offset.x="0"
    offset.y="0"
    count_min="10"
    count_max="20"
	x_pos_offset_min="0"
    y_pos_offset_min="0"
    x_pos_offset_max="0"
    y_pos_offset_max="0"
    x_vel_min="0"
    x_vel_max="0"
    y_vel_min="0"
    y_vel_max="0"
    lifetime_min="0.4"
    lifetime_max="0.6"
	fade_based_on_lifetime="1"
	airflow_force="4."
	airflow_time="1.5"
	airflow_scale="2.0"
	render_on_grid="1"
	emit_real_particles="0"
    emit_cosmetic_particles="1"
    emission_interval_min_frames="1"
    emission_interval_max_frames="2"
	area_circle_radius.max="12"
	area_circle_radius.min="8"
	velocity_always_away_from_center="-80"
    is_emitting="1" >
  </ParticleEmitterComponent>

	<CellEaterComponent
		radius="5"
		eat_dynamic_physics_bodies="1"
		ignored_material_tag="[indestructible]"
		>
	</CellEaterComponent>
	
	<VariableStorageComponent
		name="projectile_file"
		value_string="data/entities/projectiles/deck/teleport_projectile_v2.xml"
		>
	</VariableStorageComponent>

	<AudioComponent
      file="data/audio/Desktop/projectiles.bank"
      event_root="player_projectiles/spiral_shot">
  </AudioComponent>

  <AudioLoopComponent
			file="data/audio/Desktop/projectiles.bank"
			event_name="player_projectiles/wall/loop"
			set_speed_parameter="1"
			auto_play="1">
	</AudioLoopComponent>

  <LuaComponent
		remove_after_executed="1"
		script_source_file="data/scripts/projectiles/order_aim.lua" 
		execute_on_added="1">
	  </LuaComponent>

</Entity>

