<Entity 
	name="$projectile_default" tags="resist_repulsion"
	>

	<Base file="data/entities/base_projectile.xml" >
		<VelocityComponent
			gravity_y="0"
			air_friction="-10"
			mass="0.05"
			terminal_velocity="512"
			liquid_drag="0"
			>
		</VelocityComponent> 
	</Base>

	<ProjectileComponent 
		_enabled="1" 
		lob_min="0.8"
		lob_max="1.0"
		speed_min="512"
		speed_max="512"
		die_on_low_velocity="0"
		on_death_explode="1"
		on_death_gfx_leave_sprite="0" 
		on_lifetime_out_explode="1"
		explosion_dont_damage_shooter="1"
		collide_with_world="1"
		on_collision_die="1"
		lifetime="45" 
		damage="0.4"
		knockback_force="1.0"
		muzzle_flash_file="data/entities/particles/muzzle_flashes/muzzle_flash_magic_launcher_blue.xml"
		shoot_light_flash_r="225"
		shoot_light_flash_g="55"
		shoot_light_flash_b="225"
		shoot_light_flash_radius="100" 
		never_hit_player="1"
		>
		<damage_by_type
			fire="0.4"
			ice="0.4"
			slice="0.4"
			drill="0.4"
			electricity="0.4" 
			radioactive="0.4"
			holy="0.4"
			curse="0.4"
			melee="0.04"
			healing="0.004"
			>
		</damage_by_type>
		<config_explosion
		  never_cache="0" 
		  camera_shake="2" 
		  explosion_radius="12"
		  explosion_sprite="data/particles/orb_pink_big_out.xml" 
		  explosion_sprite_lifetime="0" 
		  create_cell_probability="0" 
		  hole_destroy_liquid="0" 
		  hole_enabled="1" 
		  load_this_entity="data/entities/projectiles/deck/chain_bolt_explosion.xml"
		  ray_energy="2500"
		  damage="0.6"
		  particle_effect="1"
		  damage_mortals="1"
		  physics_explosion_power.min="0.15"
		  physics_explosion_power.max="0.35" 
		  shake_vegetation="1" 
		  sparks_count_min="1" 
		  sparks_count_max="3" 
		  spark_material="plasma_fading_pink"
		  sparks_enabled="1" 
		  stains_enabled="1"
		  stains_radius="4"
		  audio_event_name="explosions/nuke"
		  >
		</config_explosion>
	</ProjectileComponent>

	<SpriteComponent 
    _enabled="0" 
    alpha="1" 
    image_file="data/entities/animals/boss_robot/trail/lance_gfx.xml" 
	has_special_scale="1"
	special_scale_x="0.5"
	special_scale_y="0.5"
    next_rect_animation=""
    rect_animation="" 
    additive="1"
     >
  	</SpriteComponent>
	
	<SpriteComponent 
    _enabled="1" 
    alpha="1" 
    image_file="data/projectiles_gfx/target2.xml" 
	has_special_scale="1"
	special_scale_x="0.7"
	special_scale_y="0.7"
    next_rect_animation="" 
    offset_x="0" 
    offset_y="0" 
    rect_animation="fireball"
	additive="1"
	emissive="1"
     >
  </SpriteComponent>

  <SpriteComponent 
    _enabled="1" 
    alpha="1" 
    image_file="data/projectiles_gfx/target2.xml" 
	has_special_scale="0"
	special_scale_x="0.7"
	special_scale_y="0.7"
    next_rect_animation="" 
    offset_x="0" 
    offset_y="0" 
    rect_animation="fireball"
	additive="1"
	emissive="1"
     >
  </SpriteComponent>

	<ParticleEmitterComponent 
		emitted_material_name="spark_purple_bright"
		offset.x="0"
		offset.y="0"
		x_pos_offset_min="-5"
		y_pos_offset_min="-5"
		x_pos_offset_max="5"
		y_pos_offset_max="5"
		x_vel_min="-9"
		x_vel_max="9"
		y_vel_min="-9"
		y_vel_max="9"
		count_min="7"
		count_max="7"
		lifetime_min="1.3"
		lifetime_max="3.7"
		create_real_particles="0"
		emit_cosmetic_particles="1"
		render_on_grid="1"
		gravity.y="0"
		fade_based_on_lifetime="1"
		emission_interval_min_frames="1"
		emission_interval_max_frames="1"
		is_emitting="1"
		velocity_always_away_from_center="-7" >
	</ParticleEmitterComponent>

	<ParticleEmitterComponent 
		emitted_material_name="plasma_fading_pink"
		offset.x="0"
		offset.y="0"
		x_pos_offset_min="-9"
		y_pos_offset_min="-9"
		x_pos_offset_max="9"
		y_pos_offset_max="9"
		x_vel_min="-15"
		x_vel_max="15"
		y_vel_min="-15"
		y_vel_max="15"
		count_min="1"
		count_max="7"
		lifetime_min="1.1"
		lifetime_max="3.7"
		create_real_particles="0"
		emit_cosmetic_particles="1"
		render_on_grid="1"
		gravity.y="0"
		fade_based_on_lifetime="1"
		emission_interval_min_frames="3"
		emission_interval_max_frames="5"
		is_emitting="1"
		velocity_always_away_from_center="-7" >
	</ParticleEmitterComponent>
	
	<LightComponent 
		_enabled="1" 
		radius="150" 
		r="30"
		g="90"
		b="30">
	</LightComponent>

	<AudioLoopComponent
		file="data/audio/Desktop/projectiles.bank"
		event_name="player_projectiles/meteor/loop"
		auto_play="1">
	</AudioLoopComponent>

	<HitEffectComponent 
        effect_hit="LOAD_UNIQUE_CHILD_ENTITY"
        value_string="data/entities/misc/sentry_target.xml" >
	</HitEffectComponent >
	
	<VariableStorageComponent
		name="projectile_file"
		value_string="data/entities/projectiles/deck/order_projectile_ex.xml"
		>
	</VariableStorageComponent>
</Entity>