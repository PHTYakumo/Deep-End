	  shoot_light_flash_r="255"
    shoot_light_flash_g="140"
    shoot_light_flash_b="10"
    shoot_light_flash_radius="150"
    penetrate_world="1"
    penetrate_world_velocity_coeff="0.5"
	  knockback_force="72.0"
	  physics_impulse_coeff="2800"
    bounce_fx_file="data/entities/misc/fire.xml"
	><damage_by_type
		fire="0.24"
    poison="0.24"
	></damage_by_type>
    <config_explosion
      not_scaled_by_gamefx="1"
      never_cache="1" 
      camera_shake="1.5" 
      explosion_radius="12" 
      explosion_sprite="data/particles/explosion_040_poof.xml" 
      explosion_sprite_lifetime="0" 
