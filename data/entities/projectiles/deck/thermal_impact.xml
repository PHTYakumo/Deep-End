	    ray_energy="50000"
      hole_image="data/temp/explosion_hole.png" 
      particle_effect="1" 
      damage_mortals="1"
	    physics_explosion_power.min="0.6" 
      physics_explosion_power.max="0.9" 
      physics_throw_enabled="1" 
      shake_vegetation="1" 
      sparks_enabled="1" 
      spark_material="spark_blue"
      sparks_count_max="4" 
      sparks_count_min="1"
      light_fade_time="0.2" 
      stains_enabled="1" 
      stains_image="data/temp/explosion_stain.png"
      audio_enabled="0" >
