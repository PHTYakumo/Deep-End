<Entity name="$projectile_default" tags="projectile_player" >

	<Base file="data/entities/base_projectile.xml" >
		<VelocityComponent
			air_friction="0.0"
			mass="0.07"
			>
		</VelocityComponent>
	</Base>

  <TeleportProjectileComponent
    min_distance_from_wall="3">
  </TeleportProjectileComponent>

  <ProjectileComponent 
    _enabled="1" 
    lob_min="0.2"
    lob_max="0.5"
    speed_min="500"
    speed_max="600"
    friction="0.4"
    direction_random_rad="0.03"
    on_death_explode="1"
    on_death_gfx_leave_sprite="0" 
    on_lifetime_out_explode="1"
    explosion_dont_damage_shooter="1" 
    on_collision_die="1"
    never_hit_player="1"
    lifetime="30"
    damage="1.4"
    velocity_sets_scale="1"
    lifetime_randomness="5"
    ragdoll_force_multiplier="0.04"
    hit_particle_force_multiplier="5.5 "
    camera_shake_when_shot="3.0"
    bounces_left="3"
    shoot_light_flash_radius="80"
	muzzle_flash_file="data/entities/particles/muzzle_flashes/muzzle_flash_launcher_large.xml"
	knockback_force="2.0"
	>
    <config_explosion
      never_cache="0" 
      camera_shake="10" 
      explosion_radius="9"
      explosion_sprite="data/particles/explosion_016.xml" 
      load_this_entity="data/entities/particles/particle_explosion/main_gunpowder_tiny.xml"
      explosion_sprite_lifetime="0" 
      create_cell_material="water_fading"
			create_cell_probability="20"
      hole_destroy_liquid="0" 
      hole_enabled="1" 
      ray_energy="25000"
      damage="0.6"
      particle_effect="0"
      damage_mortals="1"
	    physics_explosion_power.min="0.15"
      physics_explosion_power.max="0.35" 
      shake_vegetation="1" 
      sparks_count_min="4" 
      sparks_count_max="10" 
      sparks_enabled="1" 
      stains_enabled="1"
      stains_radius="12"
      audio_event_name="explosions/grenade_small" >
    </config_explosion>
  </ProjectileComponent>
  
  <SpriteComponent 
    alpha="0.2" 
    image_file="data/projectiles_gfx/grenade_teleport_small.xml" 
    next_rect_animation="" 
    offset_x="0" 
    offset_y="0" 
    rect_animation="" 
    >
  </SpriteComponent>

  <ParticleEmitterComponent 
    emitted_material_name="smoke"
    offset.x="0"
    offset.y="0"
    x_pos_offset_min="-1"
    y_pos_offset_min="-1"
    x_pos_offset_max="1"
    y_pos_offset_max="1"
    x_vel_min="-10"
    x_vel_max="10"
    y_vel_min="-10"
    y_vel_max="10"
    count_min="1"
    count_max="1"
    lifetime_min="0.2"
    lifetime_max="0.4"
    create_real_particles="1"
    emit_cosmetic_particles="0"
    emission_interval_min_frames="1"
    emission_interval_max_frames="1"
    is_emitting="1" >
  </ParticleEmitterComponent>

  <ParticleEmitterComponent 
    emitted_material_name="fire"
    offset.x="0"
	gravity.y="0.0"
    offset.y="0"
    count_min="1"
    count_max="2"
	x_pos_offset_min="-1"
    y_pos_offset_min="-1"
    x_pos_offset_max="1"
    y_pos_offset_max="1"
    x_vel_min="0"
    x_vel_max="0"
    y_vel_min="-5"
    y_vel_max="5"
	is_trail="1"
	trail_gap="1.5"
    lifetime_min="0.4"
    lifetime_max="1.8"
	airflow_force="4.1"
	airflow_time="0.101"
	airflow_scale="10.01"
    emit_real_particles="0"
	render_on_grid="1"
	fade_based_on_lifetime="1"
    emit_cosmetic_particles="1"
    emission_interval_min_frames="1"
    emission_interval_max_frames="2"
    is_emitting="1" >
  </ParticleEmitterComponent>
  
  <ParticleEmitterComponent 
    emitted_material_name="spark"
    offset.x="0"
	gravity.y="0.0"
    offset.y="0"
    count_min="70"
    count_max="140"
	x_pos_offset_min="-2"
    y_pos_offset_min="-1"
    x_pos_offset_max="2"
    y_pos_offset_max="1"
    x_vel_min="-10"
    x_vel_max="10"
    y_vel_min="-10"
    y_vel_max="10"
	is_trail="1"
	trail_gap="1.5"
    lifetime_min="0.4"
    lifetime_max="0.6"
	airflow_force="0.1"
	airflow_time="0.101"
	airflow_scale="2.01"
    emit_real_particles="0"
	fade_based_on_lifetime="1"
	airflow_force="4.1"
	airflow_time="1.501"
	airflow_scale="2.01"
	render_on_grid="1"
    emit_cosmetic_particles="1"
    emission_interval_min_frames="1"
    emission_interval_max_frames="1"
    is_emitting="1" >
  </ParticleEmitterComponent>
  
	<SpriteParticleEmitterComponent
		sprite_file="data/particles/shine_02.xml"
		delay="0"
		lifetime="2"
		color.r="1" color.g="1" color.b="1" color.a="1"
		color_change.r="0" color_change.g="0" color_change.b="0" color_change.a="-1"
		velocity.x="0" velocity.y="0"
		gravity.x="0" gravity.y="10"
		velocity_slowdown="0.5"
		rotation="0"
		angular_velocity="0"
		use_velocity_as_rotation="0"
		scale.x="1" scale.y="1"
		scale_velocity.x="0" scale_velocity.y="0"
		emission_interval_min_frames="1"
		emission_interval_max_frames="1"
		count_min="1" count_max="1"
		randomize_rotation.min="-3.1415"
		randomize_rotation.max="3.1415"
		randomize_angular_velocity.min="-1"
		randomize_angular_velocity.max="1"
		randomize_position.min_x="-3"
		randomize_position.max_x="3"
		randomize_position.min_y="-3"
		randomize_position.max_y="3"
		randomize_velocity.min_y="0"
		randomize_velocity.max_y="10"
		randomize_velocity.min_x="-2"
		randomize_velocity.max_x="2"
	>
	</SpriteParticleEmitterComponent>

  <LightComponent 
    _enabled="1" 
    radius="40" >
  </LightComponent>

  <AudioComponent
      file="data/audio/Desktop/projectiles.bank"
      event_root="projectiles/bullet_launcher"
	  >
  </AudioComponent>
  
  <VariableStorageComponent
		name="projectile_file"
		value_string="data/entities/projectiles/deck/grenade_teleport.xml"
		>
	</VariableStorageComponent>
  
</Entity>

