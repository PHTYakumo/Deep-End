<Entity name="$projectile_default" tags="resist_repulsion,projectile_player" >

	<Base file="data/entities/base_projectile.xml" >
		<VelocityComponent
			air_friction="0"
			gravity_y="0"
			mass="0.08"
			>
		</VelocityComponent>
	</Base>

  <ProjectileComponent 
    _enabled="1" 
    lob_min="12"
    lob_max="12"
    speed_min="1"
    speed_max="1"
    friction="0.2"
    direction_random_rad="0.05"
    on_death_explode="0"
    on_death_gfx_leave_sprite="0" 
    on_lifetime_out_explode="1"
    explosion_dont_damage_shooter="1" 
    on_collision_die="0"
    lifetime="2"
    damage="0.0"
    velocity_sets_scale="1"
    lifetime_randomness="0"
    ragdoll_force_multiplier="0.05"
    hit_particle_force_multiplier="0.25 "
    camera_shake_when_shot="0.1"
    muzzle_flash_file="data/entities/particles/muzzle_flashes/muzzle_flash_magic_launcher.xml"
    shoot_light_flash_r="120"
    shoot_light_flash_g="235"
    shoot_light_flash_b="90"
    shoot_light_flash_radius="100" 
	  die_on_low_velocity="1"
    die_on_low_velocity_limit="500"
	  knockback_force="39.0"
	  physics_impulse_coeff="3000"
	><damage_by_type
		melee="0.0"
	></damage_by_type>
    <config_explosion
      never_cache="1" 
      damage="0"
      camera_shake="2.0" 
      explosion_radius="9"
      explosion_sprite="" 
      explosion_sprite_lifetime="0" 
      create_cell_probability="0"
	    explosion_sprite_additive="1"
      hole_destroy_liquid="0" 
      hole_enabled="1" 
      ray_energy="300000"
      particle_effect="0" 
      damage_mortals="1"
	    physics_explosion_power.min="0.1" 
      physics_explosion_power.max="0.3" 
      physics_throw_enabled="1" 
      shake_vegetation="1" 
      sparks_count_max="1" 
      sparks_count_min="3" 
      sparks_enabled="0" 
      material_sparks_enabled="1"
      material_sparks_count_max="2"
      material_sparks_count_min="1" 
      light_enabled="0" 
      stains_enabled="0"
      stains_radius="1"
	    spark_material="spark_blue"
      audio_enabled="0"
	  >
    </config_explosion>
  </ProjectileComponent>

  <LifetimeComponent
			lifetime="3" >
	</LifetimeComponent>

  <AreaDamageComponent
		_tags="area_damage"
		aabb_min.x="-18" 
		aabb_min.y="-18" 
		aabb_max.x="18" 
		aabb_max.y="18"
		damage_per_frame="0.44"
		update_every_n_frame="1"
		entities_with_tag="homing_target"
		damage_type="DAMAGE_SLICE"
		death_cause="$dCLEAVE"
		circle_radius="18"
		>
	</AreaDamageComponent>
  
  <SpriteComponent 
    _enabled="1" 
    alpha="0.15" 
    has_special_scale="1"
	  special_scale_x="0.66"
	  special_scale_y="0.88"
    image_file="data/projectiles_gfx/katana_circle_slash.xml" 
    next_rect_animation="" 
    offset_x="0" 
    offset_y="0" 
    rect_animation="fireball"
     >
  </SpriteComponent>
	
	<LightComponent 
    _enabled="1" 
    radius="30" >
  	</LightComponent>

  	<AudioComponent
        file="data/audio/Desktop/projectiles.bank"
        event_root="player_projectiles/bullet_disc">
    </AudioComponent>
  
    <AudioLoopComponent
        file="data/audio/Desktop/projectiles.bank"
        event_name="player_projectiles/bullet_disc/loop"
        set_speed_parameter="1"
        auto_play="1">
    </AudioLoopComponent>
  
	<VariableStorageComponent
		name="projectile_file"
		value_string="data/entities/projectiles/deck/katana_circle_slash.xml"
		>
	</VariableStorageComponent>

</Entity>

