<Entity 
  name="$projectile_default" tags="projectile_player,summon_sword_root"
   >

	<Base file="data/entities/base_projectile.xml" >
		<VelocityComponent
    		gravity_y="0"
			air_friction="10"
			mass="0.01"
			terminal_velocity="32"
			>
    	</VelocityComponent> 
	</Base>

  <ProjectileComponent 
    _enabled="1" 
	lob_min="0.8"
  	lob_max="1.0"
  	speed_min="10"
  	speed_max="10"
	collide_with_entities="0"
    die_on_low_velocity="0"
    on_death_explode="0"
    on_death_gfx_leave_sprite="0" 
    on_lifetime_out_explode="0"
	explosion_dont_damage_shooter="1"
    damage="0.0"
    on_collision_die="0"
	collide_with_world="0"
	direction_random_rad="0.0"
    lifetime="999999999"
	muzzle_flash_file="data/entities/particles/muzzle_flashes/muzzle_flash_magic_large.xml"
	shoot_light_flash_r="160"
    shoot_light_flash_g="245"
    shoot_light_flash_b="255"
    shoot_light_flash_radius="180"
	damage_every_x_frames="999"
	penetrate_world="1"
	physics_impulse_coeff="5000">
  </ProjectileComponent>
  
	<LightComponent 
		_enabled="1" 
		radius="160" 
		r="150"
		g="35"
		b="120">
	</LightComponent>

	<VariableStorageComponent
		_tags="cd"
		name="cd"
		value_int="0"
	></VariableStorageComponent>
	
	<LuaComponent 
		_enabled="1"
		remove_after_executed="0"
		script_source_file="data/scripts/projectiles/sword_follow.lua"
		execute_every_n_frame="1"
	></LuaComponent>

	<LuaComponent
		remove_after_executed="1"
		script_source_file="data/scripts/projectiles/sword_spawn.lua" 
		execute_on_added="1"
	></LuaComponent>

	<AudioComponent
      file="data/audio/Desktop/projectiles.bank"
      event_root="player_projectiles/spiral_shot">
	</AudioComponent>
	
	<VariableStorageComponent
		name="projectile_file"
		value_string="data/entities/projectiles/deck/sword_summon.xml"
		>
	</VariableStorageComponent>

</Entity>