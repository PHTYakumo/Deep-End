<Entity 
  name="$projectile_default" tags="projectile_player,projectile_centipede,ultra_light,thunder"
   >

	<Base file="data/entities/base_projectile.xml" >
		<VelocityComponent
    		gravity_y="0"
			air_friction="-0.8"
			mass="0.08"
			>
    	</VelocityComponent> 
	</Base>

  	<ProjectileComponent 
		_enabled="1" 
		lob_min="0.8"
		lob_max="1.0"
		speed_min="1000"
		speed_max="1000"
		die_on_low_velocity="0"
		on_death_explode="0"
		on_death_gfx_leave_sprite="0" 
		on_lifetime_out_explode="0"
		explosion_dont_damage_shooter="0"
		damage="0.0"
		dont_collide_with_tag="player_unit"
		collide_with_world="0"
		on_collision_die="0"
		penetrate_world="1"
		bounces_left="20"
		lifetime="30"
		shoot_light_flash_r="35"
		shoot_light_flash_g="210"
		shoot_light_flash_b="255"
		shoot_light_flash_radius="90"
		knockback_force="1.6"
		never_hit_player="1"
	><damage_by_type
   		healing="0.12"
    ></damage_by_type
    ><config_explosion
		never_cache="1" 
		camera_shake="2.0" 
		explosion_radius="1" 
		explosion_sprite="" 
		explosion_sprite_lifetime="0.0" 
		create_cell_probability="1" 
		create_cell_material="rainbow_gas"
		explosion_sprite_additive="1"
		ray_energy="50000"
		hole_destroy_liquid="0" 
		hole_enabled="1" 
		damage = "0.04"
		hole_image="data/temp/explosion_hole.png" 
		particle_effect="0" 
		damage_mortals="1"
		physics_explosion_power.min="1.2"
		physics_explosion_power.max="2.2"
		physics_throw_enabled="1"
		shake_vegetation="1"  
		sparks_enabled="1" 
		sparks_count_max="8" 
		sparks_count_min="4"
		spark_material="rainbow_gas"
		light_fade_time="1.2" 
		light_r="15"
		light_g="180"
		light_b="250"
		sparks_enabled="1" 
		stains_enabled="0">
    </config_explosion>
  	</ProjectileComponent>
  
  	<SpriteComponent 
		_enabled="0" 
		alpha="1" 
		image_file="data/projectiles_gfx/glow.xml" 
		next_rect_animation="" 
		offset_x="32" 
		offset_y="32" 
		rect_animation="fireball" 
		additive="1"
		update_transform_rotation="0">
  	</SpriteComponent>

  	<SpriteParticleEmitterComponent
		sprite_file="data/particles/ssspark_$[1-7].xml"
		delay="0"
		lifetime="1.1"
		color.r="1" color.g="1" color.b="1" color.a="1"
		color_change.r="0" color_change.g="0" color_change.b="0" color_change.a="-1"
		velocity.x="0" velocity.y="0"
		gravity.x="0" gravity.y="0"
		velocity_slowdown="1"
		rotation="0"
		angular_velocity="0"
		use_velocity_as_rotation="0"
		scale.x="0.7" scale.y="0.7"
		scale_velocity.x="0" scale_velocity.y="0"
		emission_interval_min_frames="1"
		emission_interval_max_frames="1"
		count_min="1" count_max="1"
		randomize_rotation.min="-0.7"
		randomize_rotation.max="0.7"
		randomize_angular_velocity.min="-0.7"
		randomize_angular_velocity.max="0.7"
		randomize_velocity.min_x="-7"
		randomize_velocity.max_x="7"
		randomize_velocity.min_y="-7"
		randomize_velocity.max_y="7"
		entity_velocity_multiplier="0.7">
	</SpriteParticleEmitterComponent>
  
  	<LightComponent 
    	_enabled="1" 
		fade_out_time="0.15"
    	radius="300" 
    	r="80"
	  	g="40"
	  	b="120">
  	</LightComponent>

  	<LuaComponent 
		_enabled="1" 
		script_source_file="data/entities/animals/boss_limbs/orb_boss_limbs.lua" 
		execute_every_n_frame="4">
   	</LuaComponent>
  
	<VariableStorageComponent
		name="projectile_file"
		value_string="data/entities/projectiles/deck/ultimate_explosion_effect.xml"
		>
	</VariableStorageComponent>
</Entity>