<Entity 
  name="$projectile_default" tags="projectile_player,thunder"
   >

	<Base file="data/entities/base_projectile.xml" >
		<VelocityComponent
    		gravity_y="0"
			air_friction="-100.0"
			mass="0.02"
			>
    	</VelocityComponent> 
	</Base>

  <ProjectileComponent 
    _enabled="1" 
	lob_min="0.8"
  	lob_max="1.0"
  	speed_min="1800"
  	speed_max="1800"
    die_on_low_velocity="0"
    on_death_explode="1"
    on_death_gfx_leave_sprite="0" 
    on_lifetime_out_explode="1"
	explosion_dont_damage_shooter="1"
    damage="0.0"
		collide_with_world="0"
		on_collision_die="0"
    penetrate_world="1"
	bounces_left="20"
    lifetime="18"
	shoot_light_flash_r="35"
    shoot_light_flash_g="210"
    shoot_light_flash_b="255"
    shoot_light_flash_radius="90"
	knockback_force="1.6"
	><damage_by_type
   	healing="0.0004"
    ></damage_by_type>
    <config_explosion
      never_cache="1" 
      camera_shake="2.0" 
      explosion_radius="1" 
      explosion_sprite="" 
      explosion_sprite_lifetime="0.0" 
      create_cell_probability="1" 
      create_cell_material="rainbow_gas"
	  explosion_sprite_additive="1"
	  ray_energy="50000"
      hole_destroy_liquid="0" 
      hole_enabled="1" 
	  damage = "0.0004"
      hole_image="data/temp/explosion_hole.png" 
      particle_effect="0" 
      damage_mortals="1"
	  physics_explosion_power.min="1.2"
      physics_explosion_power.max="2.2"
	  physics_throw_enabled="1"
      shake_vegetation="1"  
      sparks_enabled="1" 
      sparks_count_max="8" 
      sparks_count_min="4"
	  spark_material="rainbow_gas"
      light_fade_time="1.2" 
	  light_r="15"
	  light_g="180"
      light_b="250"
      sparks_enabled="1" 
      stains_enabled="0">
    </config_explosion>
  </ProjectileComponent>
  
  <SpriteComponent 
    _enabled="0" 
    alpha="1" 
    image_file="data/projectiles_gfx/glow.xml" 
    next_rect_animation="" 
    offset_x="32" 
    offset_y="32" 
    rect_animation="fireball" 
    additive="1"
	update_transform_rotation="0"
	>
  </SpriteComponent>
  
  <LightComponent 
    _enabled="1" 
    radius="300" 
    r="80"
	  g="40"
	  b="120">
  </LightComponent>

  <ParticleEmitterComponent 
    emitted_material_name="rainbow_gas"
    offset.x="-1"
    offset.y="0"
    x_pos_offset_min="-1"
    y_pos_offset_min="-1"
    x_pos_offset_max="1"
    y_pos_offset_max="1"
    x_vel_min="-24"
    x_vel_max="24"
    y_vel_min="-6"
    y_vel_max="6"
	gravity.y="0"
    count_min="4"
    count_max="6"
    lifetime_min="0.8"
    lifetime_max="1.2"
    create_real_particles="0"
    emit_cosmetic_particles="1"
	fade_based_on_lifetime="1"
    emission_interval_min_frames="1"
    emission_interval_max_frames="2"
    is_emitting="1" >
  </ParticleEmitterComponent>
  
  <AudioComponent
      file="data/audio/Desktop/projectiles.bank"
      event_root="player_projectiles/chain_bolt">
  </AudioComponent>

  <LuaComponent 
		_enabled="1" 
		script_source_file="data/entities/animals/boss_limbs/orb_boss_limbs.lua" 
		execute_every_n_frame="2">
   </LuaComponent>
  
	<VariableStorageComponent
		name="projectile_file"
		value_string="data/entities/projectiles/deck/new_year/ultimate_explosion_effect_new_year.xml"
		>
	</VariableStorageComponent>
</Entity>