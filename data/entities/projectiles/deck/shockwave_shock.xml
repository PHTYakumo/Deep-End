  </ProjectileComponent>

  <SpriteComponent 
    _enabled="1" 
    alpha="0.3" 
	  emissive="1"
	  z_index="-1"
    image_file="data/particles/smoke_04.xml" 
    next_rect_animation=""
    rect_animation="" 
	  smooth_filtering="1"
     >
  </SpriteComponent>
  
	<VariableStorageComponent
		name="projectile_file"
		value_string="data/entities/projectiles/deck/shockwave_shock.xml"
		>
