<Entity name="$projectile_default" tags="resist_repulsion,teleportable_NOT,projectile_heal,projectile" >

  <VelocityComponent
		gravity_y="0"
		air_friction="-5.5"
		mass="1.0"
		affect_physics_bodies="1" >
	</VelocityComponent>

  <ProjectileComponent
    lob_min="0.5"
    lob_max="0.7"
    speed_min="45"
    speed_max="48"
    friction="0.0"
    direction_random_rad="0"
    on_death_explode="1"
    on_death_gfx_leave_sprite="0" 
    on_lifetime_out_explode="1"
    explosion_dont_damage_shooter="1"
    penetrate_entities="1"
    lifetime="255"
    damage="0.2"
    go_through_this_material="ice_static"
    velocity_sets_scale="1"
    velocity_sets_scale_coeff="0.25"
    lifetime_randomness="0"
    ragdoll_force_multiplier="0.09"
    hit_particle_force_multiplier="0.09"
    ragdoll_fx_on_collision="BLOOD_SPRAY"
    damage_game_effect_entities="data/entities/misc/effect_frozen_short.xml,"
	  muzzle_flash_file="data/entities/particles/muzzle_flashes/muzzle_flash_laser.xml"
    bounce_fx_file="data/entities/projectiles/deck/icey_lance_bounce_fx.xml"
    bounces_left="0"
    bounce_energy="0.75"
    bounce_always="1"
    shoot_light_flash_radius="48"
    shoot_light_flash_r="30"
    shoot_light_flash_g="170"
    shoot_light_flash_b="209" 
	  knockback_force="5.6"
    physics_impulse_coeff="512"
    ><damage_by_type 
      ice="0.4"
      drill="0.2"
      physics_hit="0.2"
      healing="-0.002"
    ></damage_by_type
    ><config_explosion
      never_cache="1" 
      damage="0"
      camera_shake="0.5" 
      explosion_radius="6" 
      explosion_sprite="" 
      explosion_sprite_lifetime="0" 
      create_cell_material="ice_static" 
      create_cell_probability="1" 
      hole_destroy_liquid="0"
      explosion_sprite_additive="1"
      hole_enabled="0" 
      ray_energy="40"
      max_durability_to_destroy="9"
      particle_effect="0" 
      damage_mortals="1"
      physics_explosion_power.min="0.1" 
      physics_explosion_power.max="0.12" 
      physics_throw_enabled="1"  
      shake_vegetation="1" 
      sparks_count_max="1" 
      sparks_count_min="1" 
      sparks_enabled="0"  
      material_sparks_enabled="0"
      material_sparks_count_max="1"
      material_sparks_count_min="0" 
      light_enabled="0" 
      light_r="30"
      light_g="170"
      light_b="210"
      stains_enabled="0"
      stains_radius="1"
      audio_event_name="materials/ice_cracked"
    ></config_explosion>
  </ProjectileComponent>
	
  <AudioComponent
      file="data/audio/Desktop/projectiles.bank"
      event_root="player_projectiles/bullet_arrow">
  </AudioComponent>
  
	<VariableStorageComponent
		name="projectile_file"
		value_string="data/entities/projectiles/deck/icey_lance.xml">
	</VariableStorageComponent>
	
	<LuaComponent
		script_source_file="data/scripts/projectiles/icey_lance.lua"
    execute_on_removed="1"
		execute_every_n_frame="-1">
	</LuaComponent>

  <MagicConvertMaterialComponent
    from_material_array="water,water_ice,water_salt,water_fading,water_static,fire,lava,water_swamp,radioactive_liquid,acid,blood_cold,blood,poison,slime"
    to_material_array="ice_static,ice_static,ice_static,ice_static,ice_static,air,rock_static,ice_static,ice_radioactive_static,ice_acid_static,ice_cold_static,ice_blood_static,ice_poison_static,ice_slime_static"
    steps_per_frame="20"
    loop="1"
    is_circle="1"
    radius="10">
  </MagicConvertMaterialComponent>

  <MagicConvertMaterialComponent
    kill_when_finished="0"
    extinguish_fire="1"
    is_circle="1"
    loop="1"
    radius="16">
  </MagicConvertMaterialComponent>

  <SpriteComponent
    _tags="projectile_file_sprite" 
    _enabled="1" 
    alpha="0.5" 
    has_special_scale="1"
    special_scale_x="0.9"
	  special_scale_y="0.6"
    image_file="data/projectiles_gfx/lance_icey.xml" 
    next_rect_animation=""
    rect_animation="" 
    additive="1">
  </SpriteComponent>

  <ParticleEmitterComponent 
    emitted_material_name="ice"
    collide_with_grid="0"
    collide_with_gas_and_fire="0"
    gravity.y="0"
    gravity.x="0"
    offset.x="-0"
    offset.y="0"
    x_pos_offset_min="-5"
    y_pos_offset_min="-5"
    x_pos_offset_max="5"
    y_pos_offset_max="5"
    x_vel_min="-1"
    x_vel_max="1"
    y_vel_min="-1"
    y_vel_max="1"
    count_min="1"
    count_max="5"
    lifetime_min="0.25"
    lifetime_max="0.75"
    create_real_particles="0"
    emit_cosmetic_particles="1"
	  fade_based_on_lifetime="1"
    emission_interval_min_frames="1"
    emission_interval_max_frames="5"
    attractor_force="0.5"
    is_emitting="1" >
  </ParticleEmitterComponent>
	
	<ParticleEmitterComponent 
		emitted_material_name="ice"
		offset.x="0"
		offset.y="0"
		gravity.y="0"
		x_pos_offset_min="-1"
		y_pos_offset_min="-1"
		x_pos_offset_max="1"
		y_pos_offset_max="1"
		x_vel_min="-10"
		x_vel_max="10"
		y_vel_min="10"
		y_vel_max="10"
		count_min="1"
		count_max="3"
		lifetime_min="0.18"
		lifetime_max="0.24"
		render_on_grid="1"
		is_trail="1"
		trail_gap="0.6"
		airflow_force="0.5"
		airflow_time="0.7"
		airflow_scale="0.9"
		fade_based_on_lifetime="1"
		create_real_particles="0"
		emit_cosmetic_particles="1"
		emission_interval_min_frames="1"
		emission_interval_max_frames="1"
		is_emitting="1">
  </ParticleEmitterComponent>

</Entity>

