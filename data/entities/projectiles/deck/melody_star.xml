<Entity 
  name="$projectile_default"
   >

	<Base file="data/entities/base_projectile.xml" >
		<VelocityComponent
    		gravity_y="0"
			air_friction="-0.1"
			>
    	</VelocityComponent> 
	</Base>

  <ProjectileComponent 
    _enabled="1" 
	lob_min="0.8"
  	lob_max="1.0"
  	speed_min="340"
  	speed_max="380"
    die_on_low_velocity="0"
    on_death_explode="1"
    on_death_gfx_leave_sprite="0" 
    on_lifetime_out_explode="1"
	explosion_dont_damage_shooter="1"
    damage="0.36"
    on_collision_die="1"
	collide_with_tag="enemy"
	collide_with_world="0"
    lifetime="360" 
	velocity_sets_rotation="1"
    velocity_updates_animation="1"
    velocity_sets_scale="0">
	<damage_by_type
		holy="0.36"
		healing="-0.12"
		>
	</damage_by_type>
    <config_explosion
		never_cache="1" 
		damage="2"
		camera_shake="0.5" 
		explosion_radius="15" 
		explosion_sprite="data/particles/explosion_016_plasma.xml" 
		load_this_entity="data/entities/particles/particle_explosion/explosion_trail_swirl_pink.xml"
		explosion_sprite_lifetime="0" 
		create_cell_probability="0" 
		hole_destroy_liquid="0"
		explosion_sprite_additive="1"
		hole_enabled="0" 
		ray_energy="350000"
		particle_effect="0"
		damage_mortals="1"
		physics_explosion_power.min="0.3" 
		physics_explosion_power.max="0.6"
		physics_throw_enabled="1"
		shake_vegetation="1" 
		sparks_count_min="1" 
		sparks_count_max="3" 
		sparks_enabled="1" 
		stains_enabled="0"
		stains_radius="6"
		audio_enabled="0" >
    </config_explosion>
  </ProjectileComponent>
  
  <SpriteComponent 
    _enabled="1" 
    alpha="0.7" 
    image_file="data/projectiles_gfx/melody_star.xml" 
    next_rect_animation=""
    rect_animation="" 
	update_transform_rotation="0"
	has_special_scale="1"
	special_scale_x="0.7"
	special_scale_y="0.7"
	>
  </SpriteComponent>

  <SpriteParticleEmitterComponent
		sprite_file="data/particles/note_$[1-4].xml"
		delay="0"
		lifetime="0.8"
		color.r="0.7" color.g="1" color.b="1" color.a="0.6"
		color_change.r="0" color_change.g="0" color_change.b="0" color_change.a="-1"
		velocity.x="0" velocity.y="0"
		gravity.x="0" gravity.y="0"
		velocity_slowdown="1"
		rotation="0"
		angular_velocity="0"
		use_velocity_as_rotation="0"
		scale.x="1" scale.y="1"
		scale_velocity.x="0" scale_velocity.y="0"
		emission_interval_min_frames="6"
		emission_interval_max_frames="6"
		count_min="1" count_max="1"
		randomize_rotation.min="-0.8"
		randomize_rotation.max="0.8"
		randomize_angular_velocity.min="-1.6"
		randomize_angular_velocity.max="1.6"
		randomize_velocity.min_x="-6"
		randomize_velocity.max_x="6"
		randomize_velocity.min_y="-6"
		randomize_velocity.max_y="6"
		entity_velocity_multiplier="0.08"
	>
	</SpriteParticleEmitterComponent>
  
  <ParticleEmitterComponent
		emitted_material_name="spark_purple_bright"
		gravity.y="0.0"
		offset.x="0"
		offset.y="0"
		gravity.y="0.0"
		x_pos_offset_min="-1"
		y_pos_offset_min="0"
		x_pos_offset_max="1"
		y_pos_offset_max="0"
		x_vel_min="-8"
		x_vel_max="8"
		y_vel_min="-8"
		y_vel_max="8"
		count_min="6"
		count_max="7"
		lifetime_min="1"
		lifetime_max="1"
		render_on_grid="1"
		is_trail="1"
		trail_gap="1.5"
		airflow_force="0.1"
		airflow_time="0.101"
		airflow_scale="2.01"
		fade_based_on_lifetime="1"
		create_real_particles="0"
		emit_cosmetic_particles="1"
		emission_interval_min_frames="1"
		emission_interval_max_frames="1"
		is_emitting="1" >
	</ParticleEmitterComponent>
	
	<ParticleEmitterComponent
		emitted_material_name="spark_yellow"
		gravity.y="0.0"
		offset.x="0"
		offset.y="0"
		gravity.y="0.0"
		x_pos_offset_min="-1"
		y_pos_offset_min="0"
		x_pos_offset_max="1"
		y_pos_offset_max="0"
		x_vel_min="-10"
		x_vel_max="10"
		y_vel_min="-10"
		y_vel_max="10"
		count_min="4"
		count_max="8"
		lifetime_min="1"
		lifetime_max="2"
		render_on_grid="1"
		is_trail="1"
		trail_gap="1.5"
		airflow_force="0.1"
		airflow_time="0.101"
		airflow_scale="2.01"
		fade_based_on_lifetime="1"
		create_real_particles="0"
		emit_cosmetic_particles="1"
		emission_interval_min_frames="1"
		emission_interval_max_frames="1"
		is_emitting="1" >
	</ParticleEmitterComponent>

	<LuaComponent 
		_enabled="1"
		remove_after_executed="0"
		script_source_file="data/scripts/projectiles/melody.lua"
		execute_every_n_frame="1">
	</LuaComponent>
	
	<VariableStorageComponent
		name="cx"
		value_float="0"
		>
	</VariableStorageComponent>

	<VariableStorageComponent
		name="cy"
		value_float="0"
		>
	</VariableStorageComponent>

	<LightComponent 
		_enabled="1"
		radius="200" >
	</LightComponent>

	<SpriteComponent 
		alpha="0.8"
		image_file="data/particles/fog_of_war_hole_128.xml"
		smooth_filtering="1"
		fog_of_war_hole="1" >
	</SpriteComponent>

  </Entity>