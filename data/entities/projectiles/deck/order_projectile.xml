<Entity 
	name="$projectile_default" tags="resist_repulsion,projectile_heal"
	>

	<Base file="data/entities/base_projectile.xml" >
		<VelocityComponent
			gravity_y="0"
			air_friction="-100"
			mass="0.05"
			liquid_drag="0"
			>
		</VelocityComponent> 
	</Base>

	<ProjectileComponent 
		_enabled="1" 
		lob_min="0.8"
		lob_max="1.0"
		speed_min="3000"
		speed_max="3000"
		die_on_low_velocity="0"
		on_death_explode="1"
		on_death_gfx_leave_sprite="0" 
		on_lifetime_out_explode="1"
		explosion_dont_damage_shooter="1"
		collide_with_world="0"
		penetrate_world_velocity_coeff="1"
		on_collision_die="1"
		lifetime="28" 
		damage="0.6"
		knockback_force="1.0"
		muzzle_flash_file="data/entities/particles/muzzle_flashes/muzzle_flash_magic_launcher_blue.xml"
		shoot_light_flash_r="50"
		shoot_light_flash_g="125"
		shoot_light_flash_b="235"
		shoot_light_flash_radius="100" 
		never_hit_player="1"
		><damage_by_type
			fire="0.4"
			ice="0.4"
			slice="0.4"
			drill="0.4"
			electricity="0.4" 
			radioactive="0.4"
			holy="0.4"
			curse="0.4"
			melee="0.04"
			healing="-0.0004"
		></damage_by_type>
		<config_explosion
		  never_cache="0" 
		  camera_shake="4" 
		  explosion_radius="14"
		  explosion_sprite="data/particles/explosion_016_plasma.xml" 
		  explosion_sprite_lifetime="0" 
		  create_cell_probability="0" 
		  hole_destroy_liquid="0" 
		  hole_enabled="1" 
		  ray_energy="25000"
		  damage="0.6"
		  particle_effect="1"
		  damage_mortals="1"
		  physics_explosion_power.min="0.15"
		  physics_explosion_power.max="0.35" 
		  shake_vegetation="1" 
		  sparks_count_min="5" 
		  sparks_count_max="6" 
		  spark_material="spark_red"
		  sparks_enabled="1" 
		  stains_enabled="1"
		  stains_radius="9"
		  audio_event_name="player_projectiles/critical_hit/create" >
		</config_explosion>
	</ProjectileComponent>
	
	<SpriteComponent 
		_enabled="1" 
		alpha="0.75" 
		image_file="data/projectiles_gfx/fireball_smaller_blue.xml" 
		next_rect_animation="" 
		offset_x="0" 
		offset_y="0" 
		rect_animation="fireball"
		additive="1"
		>
	</SpriteComponent>
	
	<ParticleEmitterComponent 
		emitted_material_name="spark_blue"
		offset.x="0"
		offset.y="0"
		x_pos_offset_min="-3"
		x_pos_offset_max="3"
		y_pos_offset_min="-1"
		y_pos_offset_max="1"
		gravity.y="0"
		x_vel_min="-2"
		x_vel_max="2"
		y_vel_min="-5"
		y_vel_max="-1"
		count_min="1"
		count_max="1"
		is_trail="1"
		trail_gap="0.6"
		fade_based_on_lifetime="1"
		lifetime_min="0.1"
		lifetime_max="0.2"
		airflow_force="10"
		airflow_time="1.5"
		airflow_scale="0.05"
		create_real_particles="0"
		emit_cosmetic_particles="1"
		render_on_grid="1"
		emission_interval_min_frames="1"
		emission_interval_max_frames="2"
		is_emitting="1" >
	</ParticleEmitterComponent>
	
	<ParticleEmitterComponent 
		emitted_material_name="spark_red"
		offset.x="0"
		offset.y="0"
		x_pos_offset_min="-1"
		x_pos_offset_max="1"
		y_pos_offset_min="-2"
		y_pos_offset_max="2"
		gravity.y="0"
		x_vel_min="-8"
		x_vel_max="8"
		y_vel_min="-5"
		y_vel_max="-1"
		count_min="2"
		count_max="5"
		is_trail="1"
		trail_gap="1.2"
		fade_based_on_lifetime="1"
		lifetime_min="0.8"
		lifetime_max="1.4"
		airflow_force="1.5"
		airflow_time="0.5"
		airflow_scale="0.05"
		create_real_particles="0"
		emit_cosmetic_particles="1"
		render_on_grid="1"
		emission_interval_min_frames="1"
		emission_interval_max_frames="2"
		is_emitting="1" >
	</ParticleEmitterComponent>

	<ParticleEmitterComponent 
		emitted_material_name="gold"
		offset.x="0"
		offset.y="0"
		x_pos_offset_min="-1"
		x_pos_offset_max="1"
		y_pos_offset_min="-2"
		y_pos_offset_max="2"
		gravity.y="0"
		x_vel_min="-8"
		x_vel_max="8"
		y_vel_min="-5"
		y_vel_max="-1"
		count_min="1"
		count_max="3"
		is_trail="1"
		trail_gap="1.2"
		fade_based_on_lifetime="1"
		lifetime_min="0.3"
		lifetime_max="0.7"
		airflow_force="1.5"
		airflow_time="0.4"
		airflow_scale="0.05"
		create_real_particles="0"
		emit_cosmetic_particles="1"
		render_on_grid="1"
		emission_interval_min_frames="3"
		emission_interval_max_frames="4"
		is_emitting="1" >
	</ParticleEmitterComponent>
	
	<LightComponent 
		_enabled="1" 
		radius="150" 
		r="30"
		g="90"
		b="30">
	</LightComponent>

	<AudioLoopComponent
		file="data/audio/Desktop/projectiles.bank"
		event_name="player_projectiles/meteor/loop"
		auto_play="1">
	</AudioLoopComponent>
	
	<VariableStorageComponent
		name="projectile_file"
		value_string="data/entities/projectiles/deck/order_projectile.xml"
		>
	</VariableStorageComponent>
</Entity>