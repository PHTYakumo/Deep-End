<Entity name="$projectile_default" tags="resist_repulsion,teleportable_NOT,thunder,projectile_heal" >

	<VelocityComponent
		gravity_y="100"
		air_friction="0.8"
		mass="0.07"
		affect_physics_bodies="1" >
	</VelocityComponent>

  <ProjectileComponent
    lob_min="0.5"
    lob_max="0.7"
    speed_min="700"
    speed_max="750"
    friction="0.4"
    direction_random_rad="0"
    on_death_explode="1"
    on_death_gfx_leave_sprite="0" 
    on_lifetime_out_explode="1"
    explosion_dont_damage_shooter="1"
    dont_collide_with_tag="player_unit"
    on_collision_die="1"
    lifetime="10"
    damage="0.04"
    velocity_sets_scale="1"
    lifetime_randomness="0"
    ragdoll_force_multiplier="0.04"
    hit_particle_force_multiplier="0.1"
	  muzzle_flash_file="data/entities/particles/muzzle_flashes/muzzle_flash_laser_green.xml"
    shoot_light_flash_r="120"
    shoot_light_flash_g="255"
    shoot_light_flash_b="80"
    shoot_light_flash_radius="72" 
	  knockback_force="1.8"
    physics_impulse_coeff="1500"
    ><damage_by_type
		melee="0.04"
    healing="-0.002"
		></damage_by_type>
    <config_explosion
    never_cache="1" 
    damage="0"
    camera_shake="0.5" 
    explosion_radius="2" 
    explosion_sprite="data/particles/explosion_008_plasma_green.xml" 
    explosion_sprite_lifetime="0" 
    create_cell_probability="0" 
    hole_destroy_liquid="0"
    explosion_sprite_additive="1"
    hole_enabled="0" 
    ray_energy="4000"
    max_durability_to_destroy="8"
    particle_effect="0" 
    damage_mortals="1"
    physics_explosion_power.min="0.02" 
    physics_explosion_power.max="0.1" 
    physics_throw_enabled="1"  
    shake_vegetation="1" 
    sparks_count_max="20" 
    sparks_count_min="7" 
    sparks_enabled="0"  
    material_sparks_enabled="0"
    material_sparks_count_max="2"
    material_sparks_count_min="0" 
    light_enabled="1" 
    light_r="40"
    light_g="90"
    light_b="10"
    stains_enabled="0"
    stains_radius="3"
    >
    </config_explosion>
  </ProjectileComponent>
  
  <SpriteComponent 
    _enabled="1" 
    alpha="0.8" 
    image_file="data/projectiles_gfx/hook.xml" 
    has_special_scale="1"
	  special_scale_x="0.8"
	  special_scale_y="0.8"
    next_rect_animation=""
    rect_animation="" 
    additive="1"
    >
  </SpriteComponent>
  
	<ParticleEmitterComponent 
		emitted_material_name="spark_teal"
		offset.x="0"
		offset.y="0"
		x_pos_offset_min="0"
		x_pos_offset_max="0"
		y_pos_offset_min="0"
		y_pos_offset_max="0"
		x_vel_min="0"
		x_vel_max="0"
		y_vel_min="0"
		y_vel_max="0"
		gravity.y="0.0"
		count_min="1"
		count_max="1"
		lifetime_min="0.7"
		lifetime_max="0.9"
		is_trail="1"
		trail_gap="1.0"
		render_on_grid="1"
		fade_based_on_lifetime="1"
		airflow_force="4.8"
		airflow_time="0.25"
		airflow_scale="3.6"
		emission_interval_min_frames="1"
		emission_interval_max_frames="1"
		emit_cosmetic_particles="1"
		create_real_particles="0"
		is_emitting="1"
    >
	</ParticleEmitterComponent>
	
  <AudioComponent
    file="data/audio/Desktop/projectiles.bank"
    event_root="player_projectiles/bullet"
    >
  </AudioComponent>
  
  <LightComponent 
    radius="40" 
  	r="40"
  	g="120"
  	b="10"
    >
  </LightComponent>

  <VariableStorageComponent
		name="projectile_file"
		value_string="data/entities/projectiles/deck/de_hook.xml"
		>
	</VariableStorageComponent>
	
	 <LuaComponent
		script_source_file="data/scripts/projectiles/special_hook.lua"
		execute_on_removed="1"
		execute_every_n_frame="600"
		>
	  </LuaComponent>

    <LuaComponent
    remove_after_executed="0"
		script_source_file="data/scripts/projectiles/homing_cursor.lua"
		execute_every_n_frame="3"
		>
	  </LuaComponent>

</Entity>

