<Entity name="$projectile_default" tags="teleportable_NOT,resist_repulsion,projectile_heal" >

  <VelocityComponent
		gravity_y="0"
    air_friction="0"
    terminal_velocity="100"
    mass="0.01"
    liquid_drag="0"
		affect_physics_bodies="1" >
	</VelocityComponent>

	<AudioComponent
		file="data/audio/Desktop/projectiles.bank"
		audio_physics_material="projectile"
		event_root="projectiles/hit" >
	</AudioComponent>

  <AudioComponent
    file="data/audio/Desktop/projectiles.bank"
    event_root="player_projectiles/summon_generic" >
  </AudioComponent>

  <ProjectileComponent 
    _enabled="1" 
    lob_min="0.2"
    lob_max="0.5"
    speed_min="80"
    speed_max="80"
    friction="1"
    direction_random_rad="0.225"
    on_death_explode="0"
    on_death_gfx_leave_sprite="0" 
    on_lifetime_out_explode="0"
    explosion_dont_damage_shooter="1" 
    on_collision_die="0"
    collide_with_world="0"
		penetrate_world_velocity_coeff="1"
    damage_every_x_frames="30"
    never_hit_player="1"
    lifetime="-1"
    damage="0"
    velocity_sets_scale="0"
    lifetime_randomness="0"
    ragdoll_force_multiplier="0.01"
    hit_particle_force_multiplier="0.1"
    camera_shake_when_shot="0"
    shoot_light_flash_radius="16"
	  knockback_force="0.01" 
    ><damage_by_type 
      healing="-0.00001" 
      holy="1"
    ></damage_by_type
    ><config_explosion
      never_cache="1" 
      camera_shake="1" 
      explosion_radius="0" 
      explosion_sprite="data/particles/explosion_016_plasma_dark.xml" 
      explosion_sprite_lifetime="0.0" 
      create_cell_probability="0" 
      create_cell_material="plasma_fading"
	    explosion_sprite_emissive="1"
	    explosion_sprite_additive="1"
	    ray_energy="10"
      hole_destroy_liquid="0" 
      hole_enabled="0" 
	    damage="0"
      hole_image="data/temp/explosion_hole.png" 
      particle_effect="0" 
      damage_mortals="0"
	    physics_throw_enabled="0"
      shake_vegetation="0"  
      sparks_enabled="0" 
	    spark_material="plasma_fading"
      sparks_count_max="1" 
      sparks_count_min="1"
      light_fade_time="1" 
	    light_r="225"
	    light_g="15"
      light_b="225"
      stains_enabled="0" 
      stains_image="data/temp/explosion_stain.png"
    ></config_explosion>
  </ProjectileComponent>

  <LifetimeComponent
		lifetime="360" >
	</LifetimeComponent>
  
  <AreaDamageComponent
    _enabled="1"
		aabb_min.x="-7.5" 
		aabb_min.y="-7.5" 
		aabb_max.x="7.5" 
		aabb_max.y="7.5"
    circle_radius="7.5"
		damage_per_frame="1"
		update_every_n_frame="10"
		entities_with_tag="homing_target"
		damage_type="DAMAGE_HOLY"
		death_cause="$damage_holy" >
	</AreaDamageComponent>

  <SpriteComponent 
    _enabled="1" 
    alpha="1" 
    z_index="-1.9"
    image_file="data/projectiles_gfx/shine_reversed.xml" 
    next_rect_animation="" 
    offset_x="0" 
    offset_y="0" 
    rect_animation="" 
    has_special_scale="1"
	  special_scale_x="1"
	  special_scale_y="1" >
  </SpriteComponent>

  <SpriteComponent 
    _enabled="1"
		alpha="1"
		image_file="data/particles/fog_of_war_hole.xml"
		smooth_filtering="1"
		fog_of_war_hole="1" >
	</SpriteComponent>
  
</Entity>

