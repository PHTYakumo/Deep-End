<Entity name="$projectile_default" tags="resist_repulsion,projectile_player,thunder,teleportable_NOT" >

	<Base file="data/entities/base_projectile.xml" >

    <VelocityComponent
      terminal_velocity="16384" 
    ></VelocityComponent>

	</Base>

  <ProjectileComponent 
    speed_min="1200"
    speed_max="1200"
    on_collision_die="0"
    on_death_explode="0"
    on_death_gfx_leave_sprite="0"
    on_lifetime_out_explode="0"
    explosion_dont_damage_shooter="0"
    lifetime="2"
    projectile_type="LIGHTNING"
    muzzle_flash_file="data/entities/particles/muzzle_flashes/muzzle_flash_laser.xml"
    damage="0"
    shoot_light_flash_r="255"
    shoot_light_flash_g="75"
    shoot_light_flash_b="75"
    shoot_light_flash_radius="208"
    >
	<damage_by_type electricity="3.0" >
    </damage_by_type>
  </ProjectileComponent>
  
  <LightningComponent 
    sprite_lightning_file="data/particles/lightning_red.png"
    is_projectile="1"
    explosion_type="1"
    >
    <config_explosion
      never_cache="1" 
      camera_shake="1.5" 
      explosion_radius="18"
      damage="0.8"
      explosion_sprite="data/particles/explosion_032_electric_red.xml"
      load_this_entity=""
      explosion_sprite_lifetime="0" 
      create_cell_probability="0"
      explosion_sprite_emissive="1"
      explosion_sprite_additive="1"
      hole_destroy_liquid="0" 
      particle_effect="0"
      sparks_inner_radius_coeff="1"
      spark_material="flame"
      hole_enabled="1" 
      hole_image="data/temp/explosion_hole.png" 
      damage_mortals="1"
      physics_explosion_power.max="3.7" 
      physics_explosion_power.max="4.5" 
      physics_throw_enabled="1" 
      shake_vegetation="1" 
      sparks_count_min="1" 
      sparks_count_max="3"
      sparks_enabled="1" 
      stains_enabled="1" 
      stains_radius="12"
      audio_enabled="0" >
    </config_explosion>
  </LightningComponent>

  <SpriteParticleEmitterComponent
    sprite_file="data/particles/spark_electric_red.xml"
    delay="0"
    lifetime="1"
    color.r="1" color.g="1" color.b="1" color.a="1"
    color_change.r="0" color_change.g="0" color_change.b="0" color_change.a="0"
    velocity.x="0" velocity.y="0"
    gravity.x="0" gravity.y="10"
    velocity_slowdown="0"
    rotation="0"
    angular_velocity="0"
    use_velocity_as_rotation="0"
    scale.x="1" scale.y="1"
    scale_velocity.x="0" scale_velocity.y="0"
    emission_interval_min_frames="5"
    emission_interval_max_frames="10"
    count_min="4" 
    count_max="5"
    randomize_rotation.min="-3.1415"
    randomize_rotation.max="3.1415"
    randomize_position.min_x="-4"
    randomize_position.max_x="4"
    randomize_position.min_y="-2"
    randomize_position.max_y="2"
    >
  </SpriteParticleEmitterComponent>

  <AreaDamageComponent
		_tags="area_damage"
		aabb_min.x="-16" 
		aabb_min.y="-16" 
		aabb_max.x="16" 
		aabb_max.y="16"
		damage_per_frame="0.4"
		update_every_n_frame="1"
		entities_with_tag="homing_target"
		damage_type="DAMAGE_SLICE"
		death_cause="$dCLEAVE"
		circle_radius="18"
		>
	</AreaDamageComponent>

  <AudioComponent
      file="data/audio/Desktop/projectiles.bank"
      event_root="player_projectiles/bullet_lightning">
  </AudioComponent>
  
	<VariableStorageComponent
		name="projectile_file"
		value_string="data/entities/projectiles/deck/lightning_red.xml"
		>
	</VariableStorageComponent>

</Entity>
