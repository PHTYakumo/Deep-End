<Entity 
  name="$projectile_default" 
   >

	<Base file="data/entities/base_projectile.xml" >
		<VelocityComponent
    		gravity_y="-90"
			mass="0.02"
			>
    	</VelocityComponent> 
	</Base>

  <ProjectileComponent 
    _enabled="1" 
	  lob_min="0.8"
	  lob_max="1.0"
	  speed_min="450"
	  speed_max="550"
	  friction="0.0"
	  direction_random_rad="0.2"
    on_death_explode="0"
    on_death_gfx_leave_sprite="0" 
    on_lifetime_out_explode="0"
    explosion_dont_damage_shooter="1" 
    die_on_low_velocity="0"
    on_collision_die="0"
    collide_with_world="0"
    lifetime="12"
    damage="0.002"
    velocity_sets_scale="0"
    lifetime_randomness="7"
    ragdoll_force_multiplier="0.01"
    hit_particle_force_multiplier="0.25 "
    camera_shake_when_shot="0.0" >
  </ProjectileComponent>

  <CellEaterComponent
		radius="4" 
		eat_probability="16"
    ignored_material_tag="[sunbaby_ignore_list]"
		>
	</CellEaterComponent>
  
  <ParticleEmitterComponent 
    emitted_material_name="acid"
    count_min="8"
    count_max="10"
    offset.x="0"
    offset.y="1"
    x_pos_offset_min="-6"
    y_pos_offset_min="-6"
    x_pos_offset_max="6"
    y_pos_offset_max="6"
    x_vel_min="-10"
    x_vel_max="10"
    y_vel_min="-10"
    y_vel_max="10"
    lifetime_min="1.1"
    lifetime_max="2.8"
    create_real_particles="1"
    emit_cosmetic_particles="0"
    emission_interval_min_frames="1"
    emission_interval_max_frames="2"
    is_emitting="1" >
  </ParticleEmitterComponent>

  <ParticleEmitterComponent 
    emitted_material_name="radioactive_liquid_fading"
    count_min="12"
    count_max="15"
    offset.x="0"
    offset.y="1"
    x_pos_offset_min="-8"
    y_pos_offset_min="-8"
    x_pos_offset_max="8"
    y_pos_offset_max="8"
    x_vel_min="-6"
    x_vel_max="6"
    y_vel_min="-6"
    y_vel_max="6"
    lifetime_min="1.1"
    lifetime_max="2.8"
    create_real_particles="1"
    emit_cosmetic_particles="0"
    emission_interval_min_frames="1"
    emission_interval_max_frames="2"
    is_emitting="1" >
  </ParticleEmitterComponent>

  <ParticleEmitterComponent 
    emitted_material_name="fire"
    count_min="12"
    count_max="15"
    offset.x="0"
    offset.y="1"
    x_pos_offset_min="-8"
    y_pos_offset_min="-8"
    x_pos_offset_max="8"
    y_pos_offset_max="8"
    x_vel_min="-6"
    x_vel_max="6"
    y_vel_min="-6"
    y_vel_max="6"
    lifetime_min="1.1"
    lifetime_max="2.8"
    create_real_particles="1"
    emit_cosmetic_particles="0"
    emission_interval_min_frames="1"
    emission_interval_max_frames="2"
    is_emitting="1" >
  </ParticleEmitterComponent>

  <AudioComponent
    file="data/audio/Desktop/projectiles.bank"
    event_root="projectiles/acid">
  </AudioComponent>
  
	<VariableStorageComponent
		name="projectile_file"
		value_string="data/entities/projectiles/acidburst.xml"
		>
	</VariableStorageComponent>
  
  <HitEffectComponent 
    effect_hit="LOAD_UNIQUE_CHILD_ENTITY"
    value_string="data/entities/misc/effect_confusion_shock.xml" >
	</HitEffectComponent >
  
</Entity>

