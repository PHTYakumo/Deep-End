<Entity tags="resist_repulsion,projectile_player" name="$projectile_default">
  
	<Base file="data/entities/base_projectile.xml"></Base>

  	<ProjectileComponent 
    lob_min="0.5"
    lob_max="0.7"
    speed_min="250"
    speed_max="270"
    friction="0.9"
    direction_random_rad="0.13"
    on_death_particle_check_concrete="1"
    on_death_explode="0"
    on_death_gfx_leave_sprite="0" 
    on_lifetime_out_explode="0"
    explosion_dont_damage_shooter="1"
    on_collision_die="1"
    lifetime="180"
    damage="0.0"
    lifetime_randomness="0"
    ragdoll_force_multiplier="0.04"
    hit_particle_force_multiplier="0.1"
	muzzle_flash_file=""
	shoot_light_flash_radius="1"
    shoot_light_flash_r="120"
    shoot_light_flash_g="40"
    shoot_light_flash_b="40"
	knockback_force="0.3"
    physics_impulse_coeff="2000"
    on_collision_spawn_entity="1"
    spawn_entity_is_projectile="1"
    spawn_entity="data/entities/projectiles/bomb_sticky.xml"
    ><config_explosion
      null_damage="1"
      never_cache="1" 
      camera_shake="1.0" 
      explosion_radius="60" 
      explosion_sprite="data/particles/explosion_040_poof.xml"
      load_this_entity=""
      explosion_sprite_lifetime="0" 
      create_cell_probability="5" 
      create_cell_material="smoke_explosion" 
      ray_energy="17000"
      hole_destroy_liquid="1" 
      damage="5"
      hole_enabled="0" 
      hole_image="data/temp/explosion_hole.png" 
      particle_effect="1" 
      damage_mortals="0" 
      physics_explosion_power.min="0.9"
      physics_explosion_power.max="1.3" 
      physics_throw_enabled="1" 
      shake_vegetation="1" 
      sparks_enabled="0" 
      sparks_count_max="5" 
      sparks_count_min="4"
      light_fade_time="0.6" 
      stains_enabled="0" 
      stains_image="data/temp/explosion_stain.png" 
      audio_event_name="explosions/magic_grenade_small" >
    </config_explosion>
  	</ProjectileComponent>

  	<LifetimeComponent 
		lifetime="180" >
	</LifetimeComponent>

	<ParticleEmitterComponent 
		emitted_material_name="wax"
		offset.x="0"
		offset.y="0"
		x_pos_offset_min="0"
		x_pos_offset_max="0"
		y_pos_offset_min="0"
		y_pos_offset_max="0"
		x_vel_min="-2"
		x_vel_max="2"
		y_vel_min="-20"
		y_vel_max="-10"
		gravity.y="0"
		count_min="1"
		count_max="1"
		lifetime_min="0.2"
		lifetime_max="0.7"
		fade_based_on_lifetime="1"
		create_real_particles="0"
		emit_cosmetic_particles="1"
		emission_interval_min_frames="1"
		emission_interval_max_frames="1"
		is_trail="1"
		trail_gap="8"
		is_emitting="1" >
	</ParticleEmitterComponent>

	<SpriteComponent 
		image_file="data/items_gfx/bomb_sticky.png" 
		offset_x="3.5"
		offset_y="3.5"
		z_index="-1.3" >
	</SpriteComponent>

	<AudioComponent
		file="data/audio/Desktop/projectiles.bank"
		event_root="projectiles/bullet_launcher" >
	</AudioComponent>

	<LightComponent 
		radius="8" 
		r="40"
		g="40"
		b="40" >
	</LightComponent>
  
	<VariableStorageComponent
		name="projectile_file"
		value_string="data/entities/projectiles/bomb_sticky_shoot.xml" >
	</VariableStorageComponent>

</Entity>

