<Entity 
  name="$projectile_default" 
   >

	<Base file="data/entities/base_projectile.xml" >
		<VelocityComponent
    	gravity_y="0"
			air_friction="-1"
			mass="0.9"
			>
    	</VelocityComponent> 
	</Base>

  <ProjectileComponent 
    _enabled="1" 
	  lob_min="0.8"
  	lob_max="1.0"
  	speed_min="100"
  	speed_max="120"
    die_on_low_velocity="0"
    on_death_explode="1"
    on_death_gfx_leave_sprite="0" 
    on_lifetime_out_explode="1"
	  explosion_dont_damage_shooter="1"
    damage="0"
    collide_with_world="0"
    penetrate_world="1"
    on_collision_die="0"
    damage_every_x_frames="10"
	  spawn_entity=""
    lifetime="100"
	  shoot_light_flash_r="65"
    shoot_light_flash_g="210"
    shoot_light_flash_b="255"
    shoot_light_flash_radius="160"
	  knockback_force="3.0"
    bounce_always="1"
    bounces_left="1"
    bounce_energy="0.9"
	  ><damage_by_type 
		  electricity="0.3" 
	  ></damage_by_type
    ><config_explosion
      never_cache="1" 
      camera_shake="30.5" 
      explosion_radius="50" 
      explosion_sprite="data/particles/explosion_032_electric.xml"
	    load_this_entity="data/entities/particles/particle_explosion/main_blue.xml,data/entities/misc/loose_ground.xml"
      explosion_sprite_lifetime="0.0" 
      create_cell_probability="4" 
      create_cell_material="plasma_fading" 
	    explosion_sprite_emissive="1"
	    explosion_sprite_additive="1"
	    ray_energy="700000"
      hole_destroy_liquid="1" 
      hole_enabled="1" 
	    damage="1.8"
      hole_image="data/temp/explosion_hole.png" 
      particle_effect="0" 
      damage_mortals="1" 
	    physics_explosion_power.min="1.5"
      physics_explosion_power.max="2.6" 
	    physics_throw_enabled="1"
      shake_vegetation="1"  
      sparks_enabled="1" 
      sparks_count_max="15" 
      sparks_count_min="30"
	    spark_material="spark_blue"
      light_fade_time="1.2" 
	    light_r="45"
	    light_g="120"
      light_b="150"
      stains_enabled="1" 
      stains_image="data/temp/explosion_stain.png"
      audio_event_name="explosions/electric" >
    </config_explosion>
  </ProjectileComponent>
  
  <SpriteComponent 
    _enabled="1" 
    alpha="0.66" 
    image_file="data/projectiles_gfx/thunderball.xml" 
    next_rect_animation=""  
    rect_animation="fireball" 
	  emissive="1"
    additive="1"
    has_special_scale="1"
	  special_scale_x="1.3"
	  special_scale_y="1.3"
	  update_transform_rotation="1"
	></SpriteComponent>
  
  <SpriteParticleEmitterComponent
    sprite_file="data/particles/spark_electric.xml"
    delay="0"
    lifetime="0"
    color.r="1" color.g="1" color.b="1" color.a="1"
    color_change.r="0" color_change.g="0" color_change.b="0" color_change.a="0"
    velocity.x="0" velocity.y="0"
    gravity.x="0" gravity.y="10"
    velocity_slowdown="0"
    rotation="0"
    angular_velocity="0"
    use_velocity_as_rotation="0"
    scale.x="1" scale.y="1"
    scale_velocity.x="0" scale_velocity.y="0"
    emission_interval_min_frames="1"
    emission_interval_max_frames="2"
    count_min="1" count_max="3"
    randomize_rotation.min="-3.1415"
    randomize_rotation.max="3.1415"
    randomize_position.min_x="-19"
    randomize_position.max_x="19"
    randomize_position.min_y="-19"
    randomize_position.max_y="19"
    >
  </SpriteParticleEmitterComponent>
  
  <LuaComponent
	  execute_every_n_frame="10"
	  script_source_file="data/scripts/projectiles/thunderball_line.lua"
	  >
	</LuaComponent>

  <LuaComponent
	  execute_every_n_frame="40"
    remove_after_executed="1"
	  script_source_file="data/scripts/projectiles/proj_substantialize.lua"
	  >
	</LuaComponent>

  <AudioComponent
    file="data/audio/Desktop/projectiles.bank"
    event_root="projectiles/electric">
  </AudioComponent>

  <AudioLoopComponent
      file="data/audio/Desktop/projectiles.bank"
      event_name="projectiles/electric/loop"
      auto_play="1">
  </AudioLoopComponent>
  
	<VariableStorageComponent
		name="projectile_file"
		value_string="data/entities/projectiles/thunderball_line.xml"
		>
	</VariableStorageComponent>
	
	<HomingComponent
		homing_targeting_coeff="80.0"
		homing_velocity_multiplier="0.83"
		detect_distance="60"
	  >
	</HomingComponent>
 </Entity>