<Entity name="$projectile_default" >

  <Base file="data/entities/base_projectile_physics.xml">

    <PhysicsImageShapeComponent 
      image_file="data/items_gfx/bomb_holy_giga.png"
      material="fuse_holy" >
    </PhysicsImageShapeComponent>
  
    <ProjectileComponent
      lifetime="999999"
      damage="0"
      muzzle_flash_file="data/entities/particles/muzzle_flashes/muzzle_flash_magic_launcher_holy.xml"
      shoot_light_flash_radius="120"
      shoot_light_flash_r="255"
      shoot_light_flash_g="240"
      shoot_light_flash_b="30"
      ><config_explosion
		  never_cache="0" 
		  damage="0.002"
		  camera_shake="2" 
		  explosion_radius="2" 
		  explosion_sprite="data/particles/explosion_128.xml" 
		  explosion_sprite_lifetime="0" 
		  load_this_entity=""
		  create_cell_probability="2" 
		  hole_destroy_liquid="1" 
		  hole_enabled="1" 
		  ray_energy="170"
		  particle_effect="1" 
		  damage_mortals="1"
		  physics_explosion_power.min="1"
		  physics_explosion_power.max="1" 
		  shake_vegetation="1" 
		  sparks_count_max="2" 
		  sparks_count_min="1" 
		  sparks_enabled="1" 
		  stains_enabled="0" 
		  stains_radius="2"
		  background_lightning_count="2" 
		  max_durability_to_destroy="1" 
      audio_event_name="explosions/holy" 
      >
      </config_explosion>
    </ProjectileComponent>

    <PhysicsThrowableComponent
      _tags="enabled_in_world"
      throw_force_coeff="1.35" >
    </PhysicsThrowableComponent>

  </Base>

  <AudioComponent
      file="data/audio/Desktop/projectiles.bank"
      event_root="player_projectiles/bomb_holy">
  </AudioComponent>

  <AudioLoopComponent
    file="data/audio/Desktop/projectiles.bank"
    event_name="projectiles/fuse_burn_magic"
    auto_play="1">
  </AudioLoopComponent>
  
  <VariableStorageComponent
		name="projectile_file"
		value_string="data/entities/projectiles/bomb_holy_lol.xml"
		>
	</VariableStorageComponent>
  
</Entity>
