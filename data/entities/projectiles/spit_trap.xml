<Entity 
  name="$projectile_default" 
   >

	<Base file="data/entities/base_projectile.xml" >
		<VelocityComponent
    		gravity_y="0"
			mass="0.02"
			>
    	</VelocityComponent> 
	</Base>

  <ProjectileComponent 
    _enabled="1" 
	lob_min="0.8"
	lob_max="1.0"
	speed_min="66"
	speed_max="66"
	friction="0.0"
    on_death_explode="0"
    on_death_gfx_leave_sprite="0" 
    on_lifetime_out_explode="0"
    explosion_dont_damage_shooter="1" 
    die_on_low_velocity="0"
    on_collision_die="0"
    lifetime="120"
	damage="0.2"
	penetrate_entities="1"
	penetrate_world="1"
	velocity_sets_scale="0"
	lifetime_randomness="7"
	ragdoll_force_multiplier="0.01"
	hit_particle_force_multiplier="0.25"
	camera_shake_when_shot="0.0" >
  </ProjectileComponent>

  <ParticleEmitterComponent 
    emitted_material_name="magic_liquid_weakness"
    offset.x="0"
    offset.y="1"
    x_pos_offset_min="-4"
    y_pos_offset_min="-4"
    x_pos_offset_max="4"
    y_pos_offset_max="4"
    x_vel_min="-5"
    x_vel_max="5"
    y_vel_min="-5"
    y_vel_max="5"
    count_min="1"
    count_max="2"
    lifetime_min="1.0"
    lifetime_max="2.0"
    create_real_particles="1"
    emit_cosmetic_particles="0"
    emission_interval_min_frames="1"
    emission_interval_max_frames="1"
    is_emitting="1" >
  </ParticleEmitterComponent>

  <SpriteComponent 
		_enabled="1" 
		alpha="0.5" 
		image_file="data/projectiles_gfx/slimeball_yellow.xml" 
    has_special_scale="1"
	  special_scale_x="0.5"
	  special_scale_y="0.5"
		next_rect_animation="" 
		offset_x="0" 
		offset_y="0" 
		rect_animation="" 
		update_transform_rotation="0"
		>
	</SpriteComponent>

  <AudioComponent
      file="data/audio/Desktop/projectiles.bank"
      event_root="projectiles/acid">
  </AudioComponent>
  
	<VariableStorageComponent
		name="projectile_file"
		value_string="data/entities/projectiles/acidburst.xml"
		>
	</VariableStorageComponent>
  
</Entity>

