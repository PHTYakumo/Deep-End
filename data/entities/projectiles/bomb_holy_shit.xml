<Entity name="$projectile_default" >

  <Base file="data/entities/base_projectile_physics.xml">

    <PhysicsBodyComponent 
      linear_damping="-4" 
      angular_damping="0"
      buoyancy="16" >
    </PhysicsBodyComponent>

    <PhysicsImageShapeComponent 
      image_file="data/items_gfx/bomb.png"
      material="meat_confusion" >
    </PhysicsImageShapeComponent>

    <DamageModelComponent 
    hp="9999"
    ui_report_damage="0">
  </DamageModelComponent>
  
    <ProjectileComponent
      lifetime="90"
	  damage="0"
	  muzzle_flash_file="data/entities/particles/muzzle_flashes/muzzle_flash_launcher_large.xml"
	  shoot_light_flash_radius="120"
	  shoot_light_flash_r="255"
	  shoot_light_flash_g="240"
	  shoot_light_flash_b="30"
      ><config_explosion
        never_cache="0" 
        damage="0.03"
        camera_shake="2" 
        explosion_radius="60" 
        explosion_sprite="data/particles/explosion_128.xml" 
        explosion_sprite_lifetime="0" 
        load_this_entity="data/entities/particles/treble_eye.xml"
        create_cell_probability="1"
        create_cell_material="material_rainbow" 
        hole_destroy_liquid="1" 
        hole_enabled="1" 
        ray_energy="6000000"
        particle_effect="1" 
        damage_mortals="1"
        physics_explosion_power.min="7.2" 
        physics_explosion_power.max="9.6" 
        physics_throw_enabled="1"
        shake_vegetation="1" 
        sparks_count_min="12" 
        sparks_count_max="15" 
        sparks_enabled="0" 
        stains_enabled="0" 
        stains_radius="15" 
		    max_durability_to_destroy="9"
        audio_event_name="player_projectiles/critical_hit/create" >
      </config_explosion>
    </ProjectileComponent>

    <PhysicsThrowableComponent
      _tags="enabled_in_world"
      throw_force_coeff="0.75" >
    </PhysicsThrowableComponent>

  </Base>

  <ParticleEmitterComponent 
    emitted_material_name="spark"
    offset.x="-1"
    offset.y="-3"
    fade_based_on_lifetime="1"
    x_pos_offset_min="-1"
    y_pos_offset_min="-1"
    x_pos_offset_max="1"
    y_pos_offset_max="1"
    x_vel_min="-10"
    x_vel_max="10"
    y_vel_min="-10"
    y_vel_max="10"
    count_min="1"
    count_max="2"
    lifetime_min="0.1"
    lifetime_max="0.3"
    create_real_particles="0"
    emit_cosmetic_particles="1"
    emission_interval_min_frames="1"
    emission_interval_max_frames="1"
    is_emitting="1" >
  </ParticleEmitterComponent>

  <ParticleEmitterComponent 
    emitted_material_name="spark"
    offset.x="-1"
    offset.y="-3"
    x_vel_min="10"
    x_vel_max="20"
    y_vel_min="0"
    y_vel_max="0"
    gravity.y="0.0"
    count_min="1"
    count_max="1"
    lifetime_min="1.4"
    lifetime_max="1.5"
    is_trail="0"
    trail_gap="8.0"
    render_on_grid="1"
    fade_based_on_lifetime="1"
    airflow_force="0.5"
    airflow_time="0.5"
    airflow_scale="0.05"
    emission_interval_min_frames="10"
    emission_interval_max_frames="30"
    emit_cosmetic_particles="1"
    create_real_particles="0"
    is_emitting="1" >
  </ParticleEmitterComponent>

  <AudioComponent
      file="data/audio/Desktop/projectiles.bank"
      event_root="player_projectiles/bomb_holy">
  </AudioComponent>

  <AudioLoopComponent
    file="data/audio/Desktop/projectiles.bank"
    event_name="projectiles/fuse_burn_magic"
    auto_play="1">
  </AudioLoopComponent>
  
  <VariableStorageComponent
		name="projectile_file"
		value_string="data/entities/projectiles/bomb_holy_shit.xml"
		>
	</VariableStorageComponent>

</Entity>
