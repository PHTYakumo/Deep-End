<Entity tags="hittable,projectile">

  <VelocityComponent
    affect_physics_bodies="1" >
  </VelocityComponent>

  <DamageModelComponent 
    air_needed="0" 
    blood_material="" 
    drop_items_on_death="0" 
    falling_damages="0" 
    fire_damage_amount="0.2" 
    fire_probability_of_ignition="0" 
    hp="5" 
    is_on_fire="0" 
    materials_create_messages="0" 
    materials_damage="1" 
    materials_that_damage="lava"
    materials_how_much_damage="0.001"
    ragdoll_filenames_file=""
    ragdoll_material="" >
  </DamageModelComponent>

  <ProjectileComponent
    on_lifetime_out_explode="1"
    on_death_explode="1"
    on_death_gfx_leave_sprite="0"
    do_moveto_update="0"
    lifetime="180"
    damage="0"
    muzzle_flash_file=""
    shoot_light_flash_radius="12"
    shoot_light_flash_r="255"
    shoot_light_flash_g="240"
    shoot_light_flash_b="30"
    ><config_explosion
      never_cache="0" 
      damage="5"
      camera_shake="50" 
      explosion_radius="60" 
      explosion_sprite="data/particles/explosion_128.xml" 
      explosion_sprite_lifetime="0" 
      load_this_entity="data/entities/particles/particle_explosion/main_gunpowder_large.xml,data/entities/misc/explosion_was_here.xml"
      create_cell_probability="5" 
      create_cell_material="smoke_explosion" 
      hole_destroy_liquid="0" 
      hole_enabled="1" 
      ray_energy="2000000"
      particle_effect="1" 
      damage_mortals="1"
      physics_explosion_power.min="2.2" 
      physics_explosion_power.max="3.6" 
      physics_throw_enabled="1"
      shake_vegetation="1" 
      sparks_count_min="12" 
      sparks_count_max="15" 
      sparks_enabled="1" 
      stains_enabled="0" 
      stains_radius="15" 
      max_durability_to_destroy="11" 
    ></config_explosion>
  </ProjectileComponent>

  <ParticleEmitterComponent 
    emitted_material_name="smoke"
    offset.x="-1"
    offset.y="-3"
    x_pos_offset_min="-1"
    y_pos_offset_min="-1"
    x_pos_offset_max="1"
    y_pos_offset_max="1"
    x_vel_min="-10"
    x_vel_max="10"
    y_vel_min="-10"
    y_vel_max="10"
    count_min="0"
    count_max="1"
    lifetime_min="0.1"
    lifetime_max="0.3"
    create_real_particles="1"
    emit_cosmetic_particles="0"
    emission_interval_min_frames="1"
    emission_interval_max_frames="1"
    is_emitting="1" >
  </ParticleEmitterComponent>

  <SpriteComponent
    _tags="enabled_in_world"
		image_file="data/enemies_gfx/mine_emissive.xml"
    alpha="0.25"
		offset_x="0" 
    offset_y="0" 
	  z_index="-1.3"
    has_special_scale="1"
	  special_scale_x="0.5"
	  special_scale_y="0.5"
    emissive="1"
	  additive="1"
    rect_animation="detonate" >
	</SpriteComponent>

  <LuaComponent
		_tags="enable_when_player_seen"
		_enabled="0"
		script_source_file="data/scripts/projectiles/bomb_sticky_follow.lua"
		execute_every_n_frame="1" >
	</LuaComponent>
	
	<LuaComponent
    execute_on_added="1"
    remove_after_executed="1"
    script_source_file="data/scripts/projectiles/bomb_sticky_init.lua"
    execute_every_n_frame="-1" >
	</LuaComponent>

  <LifetimeComponent 
		lifetime="180" >
	</LifetimeComponent>

  <VariableStorageComponent
    _tags="enable_when_player_seen"
		name="bind_id"
		value_int="-1" >
	</VariableStorageComponent>
  
  <VariableStorageComponent
		name="projectile_file"
		value_string="data/entities/projectiles/bomb_sticky.xml" >
	</VariableStorageComponent>

  <AudioComponent
    file="data/audio/Desktop/projectiles.bank"
    event_root="player_projectiles/bomb" >
  </AudioComponent>

  <AudioLoopComponent
    file="data/audio/Desktop/projectiles.bank"
    event_name="projectiles/fuse_burn_slow"
    auto_play="1" >
  </AudioLoopComponent>

</Entity>
