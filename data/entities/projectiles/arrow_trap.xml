<Entity 
  name="$projectile_default" 
   >

	<Base file="data/entities/base_projectile.xml" >
		<VelocityComponent
		  gravity_y="250"
		  air_friction="0.6"
		  mass="0.07"
		  >
		</VelocityComponent>
	</Base>

  <ProjectileComponent 
    _enabled="1" 
    lob_min="0.5"
    lob_max="0.7"
    speed_min="250"
    speed_max="350"
    friction="1"
    direction_random_rad="0.01"
    on_death_explode="0"
    on_death_gfx_leave_sprite="1" 
    on_lifetime_out_explode="0"
    explosion_dont_damage_shooter="1"
    on_collision_die="1"
    on_collision_remove_projectile="0"
    lifetime="750"
    damage="0.5"
    damage_scaled_by_speed="1"
    lifetime_randomness="7"
    ragdoll_force_multiplier="0"
    hit_particle_force_multiplier="0.1"
    create_shell_casing="0"
    muzzle_flash_file=""
    shoot_light_flash_radius="0"
    die_on_low_velocity="1"
    die_on_low_velocity_limit="5"
    collide_with_shooter_frames="6"
    friendly_fire="0"
    velocity_sets_scale="0"
	  knockback_force="1.0"
     >
    <config_explosion>
    </config_explosion>
  </ProjectileComponent>

  <ParticleEmitterComponent 
		emitted_material_name="spark_red_bright"
		offset.x="0"
		offset.y="3"
		fade_based_on_lifetime="1"
		render_on_grid="1"
		x_pos_offset_min="-2"
		y_pos_offset_min="-1"
		x_pos_offset_max="2"
		y_pos_offset_max="1"
		airflow_force="0.3"
		airflow_time="0.2"
		airflow_scale="0.05"
		gravity.y="0"
		count_min="1"
		count_max="2"
		is_trail="1"
		trail_gap="4"
		lifetime_min="0.4"
		lifetime_max="1.3"
		create_real_particles="0"
		emit_cosmetic_particles="1"
		emission_interval_min_frames="1"
		emission_interval_max_frames="3"
		is_emitting="1" >
	</ParticleEmitterComponent>
  
  <SpriteComponent 
    _enabled="1" 
    alpha="1" 
    image_file="data/projectiles_gfx/arrow.xml" 
    has_special_scale="1"
	  special_scale_x="0.9"
	  special_scale_y="0.9"
    next_rect_animation=""
    rect_animation="" 
     >
  </SpriteComponent>
  
  <AudioComponent
		file="data/audio/Desktop/projectiles.bank"
		event_root="projectiles/bullet_arrow">
	</AudioComponent>
	
	<VariableStorageComponent
		name="projectile_file"
		value_string="data/entities/projectiles/arrow_trap.xml"
		>
	</VariableStorageComponent>

  <HitEffectComponent 
        effect_hit="LOAD_UNIQUE_CHILD_ENTITY"
        value_string="data/entities/misc/effect_homing_shooter_strong.xml" >
	</HitEffectComponent >

</Entity>

