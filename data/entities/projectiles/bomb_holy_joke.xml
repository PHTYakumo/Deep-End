<Entity name="$projectile_default" >

  <Base file="data/entities/base_projectile_physics.xml">

    <PhysicsImageShapeComponent 
      image_file="data/items_gfx/bomb_holy_giga.png"
      material="physics_throw_material_part2" >
    </PhysicsImageShapeComponent>

    <ProjectileComponent
	    damage="0"
      ><config_explosion
		    damage="0.002"
      ></config_explosion>
    </ProjectileComponent>

    <PhysicsThrowableComponent
      _tags="enabled_in_world"
      throw_force_coeff="1.35" >
    </PhysicsThrowableComponent>

  </Base>

  <!-- fx -->
  
  <ParticleEmitterComponent 
    emitted_material_name="spark"
    offset.x="-1"
    offset.y="-8"
    fade_based_on_lifetime="1"
    x_pos_offset_min="-1"
    y_pos_offset_min="-1"
    x_pos_offset_max="1"
    y_pos_offset_max="1"
    x_vel_min="-10"
    x_vel_max="10"
    y_vel_min="-10"
    y_vel_max="10"
	  gravity.y="0"
    count_min="4"
    count_max="8"
    lifetime_min="0.1"
    lifetime_max="1.3"
	  airflow_force="0.5"
    airflow_time="0.5"
    airflow_scale="0.05"
    create_real_particles="0"
    emit_cosmetic_particles="1"
    emission_interval_min_frames="1"
    emission_interval_max_frames="1"
    is_emitting="1" >
  </ParticleEmitterComponent>

  <!-- very sparse emitter -->
  <ParticleEmitterComponent 
    emitted_material_name="spark"
    offset.x="-1"
    offset.y="-8"
    x_vel_min="10"
    x_vel_max="20"
    y_vel_min="0"
    y_vel_max="0"
    gravity.y="0.0"
    count_min="1"
    count_max="2"
    lifetime_min="1.4"
    lifetime_max="1.5"
    is_trail="0"
    trail_gap="8.0"
    render_on_grid="1"
    fade_based_on_lifetime="1"
    airflow_force="0.5"
    airflow_time="0.5"
    airflow_scale="0.05"
    emission_interval_min_frames="3"
    emission_interval_max_frames="5"
    emit_cosmetic_particles="1"
    create_real_particles="0"
    is_emitting="1" >
  </ParticleEmitterComponent>

  <AudioComponent
      file="data/audio/Desktop/projectiles.bank"
      event_root="player_projectiles/bomb_holy">
  </AudioComponent>

  <AudioLoopComponent
    file="data/audio/Desktop/projectiles.bank"
    event_name="projectiles/fuse_burn_magic"
    auto_play="1">
  </AudioLoopComponent>
  
</Entity>
