<Entity tags="card_action">	

	<Base file="data/entities/base_custom_card.xml" > 
		<SpriteComponent 
			image_file="data/ui_gfx/gun_actions/deep_end/death_ray_torch.png" >
		</SpriteComponent>
		
		<ItemActionComponent 
			_tags="enabled_in_world"
			action_id="DE_DEATH_RAY_TORCH" >
		</ItemActionComponent>
	</Base>

    <InheritTransformComponent
		_tags="enabled_in_world,enabled_in_hand" >
	  <Transform 
		position.x="9" 
		position.y="0" >
	  </Transform>
	</InheritTransformComponent>

	<GameEffectComponent 
		_tags="enabled_in_hand"
        effect="STUN_PROTECTION_FREEZE"
        frames="-1"
    ></GameEffectComponent >

    <AreaDamageComponent
        _tags="enabled_in_hand,item_identified"
        aabb_min.x="-9" 
        aabb_min.y="-9" 
        aabb_max.x="9" 
        aabb_max.y="9" 
        damage_per_frame="0.48"
        update_every_n_frame="2"
        entities_with_tag="enemy"
        death_cause="$DEATH_RAY_TORCH"
        damage_type="DAMAGE_CURSE"
        circle_radius="9"
        >
    </AreaDamageComponent>

    <ParticleEmitterComponent 
		_tags="enabled_in_hand,item_identified"
		emitted_material_name="poison"
		offset.x="0"
		offset.y="0"
		x_pos_offset_min="-3"
		x_pos_offset_max="3"
		y_pos_offset_min="3"
		y_pos_offset_max="-3"
		x_vel_min="-23"
		x_vel_max="23"
		y_vel_min="-28"
		y_vel_max="-28"
		count_min="12"
		count_max="28"
		gravity.y="0"
		lifetime_min="0.2"
		lifetime_max="0.3"
		create_real_particles="0"
		emit_cosmetic_particles="1"
		emission_interval_min_frames="2"
		emission_interval_max_frames="3"
		is_emitting="1" >
	</ParticleEmitterComponent>

	<ParticleEmitterComponent 
		_tags="enabled_in_hand,item_identified"
		emitted_material_name="poison_gas"
		offset.x="0"
		offset.y="0"
		x_pos_offset_min="-3"
		x_pos_offset_max="3"
		y_pos_offset_min="3"
		y_pos_offset_max="-3"
		x_vel_min="-21"
		x_vel_max="21"
		y_vel_min="-24"
		y_vel_max="-24"
		count_min="3"
		count_max="6"
		gravity.y="0"
		lifetime_min="0.3"
		lifetime_max="0.4"
		create_real_particles="0"
		emit_cosmetic_particles="1"
		emission_interval_min_frames="2"
		emission_interval_max_frames="3"
		is_emitting="1" >
	</ParticleEmitterComponent>

    <ParticleEmitterComponent 
		_tags="enabled_in_world,enabled_in_hand,item_identified"
		emitted_material_name="poison"
		offset.x="0"
		offset.y="0"
		x_pos_offset_min="-6"
		x_pos_offset_max="6"
		y_pos_offset_min="1"
		y_pos_offset_max="-4"
		x_vel_min="-15"
		x_vel_max="15"
		y_vel_min="-35"
		y_vel_max="-10"
		count_min="4"
		count_max="7"
		gravity.y="0"
		lifetime_min="0.4"
		lifetime_max="1.1"
		create_real_particles="0"
		emit_cosmetic_particles="1"
		emission_interval_min_frames="5"
		emission_interval_max_frames="13"
		is_emitting="1" >
	</ParticleEmitterComponent>

	<LightComponent 
		_tags="enabled_in_hand,item_identified"
		_enabled="1" 
		radius="130"
		fade_out_time="1.5" 
		r="240"
		g="180"
		b="120" >
	</LightComponent>

    <SpriteComponent 
	    _tags="enabled_in_hand"
        alpha="0.2"
        image_file="data/particles/torch_fog_of_war_hole.xml"
        smooth_filtering="1"
        fog_of_war_hole="1"
        has_special_scale="1"
        special_scale_x="6"
        special_scale_y="6" >
    </SpriteComponent>

    <AudioComponent
	    _tags="enabled_in_hand"
		file="data/audio/Desktop/projectiles.bank"
		event_root="player_projectiles/torch_electric"
		set_latest_event_position="1" >
	</AudioComponent>

    <AudioLoopComponent
	    _tags="enabled_in_hand"
		file="data/audio/Desktop/projectiles.bank"
		event_name="player_projectiles/torch/loop"
		auto_play_if_enabled="1"
		play_on_component_enable="1" >
	</AudioLoopComponent>
    
</Entity>