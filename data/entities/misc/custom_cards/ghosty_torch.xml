<Entity tags="card_action">	

	<Base file="data/entities/base_custom_card.xml" > 
		<SpriteComponent 
			image_file="data/ui_gfx/gun_actions/deep_end/ghosty_torch.png" >
		</SpriteComponent>
		
		<ItemActionComponent 
			_tags="enabled_in_world"
			action_id="DE_GHOSTY_TORCH" >
		</ItemActionComponent>
	</Base>

    <InheritTransformComponent
		_tags="enabled_in_world,enabled_in_hand" >
	  <Transform 
		position.x="9" 
		position.y="0" >
	  </Transform>
	</InheritTransformComponent>

	<GameEffectComponent 
		_tags="enabled_in_hand"
        effect="STUN_PROTECTION_FREEZE"
        frames="-1" >
    </GameEffectComponent>

	<MagicConvertMaterialComponent
		_tags="enabled_in_hand,enabled_in_world,item_identified"
		from_material_array="water,water_ice,fire,lava,radioactive_liquid,acid,blood_cold,blood,poison"
		to_material_array="ice_static,ice_static,air,rock_static,ice_radioactive_static,ice_acid_static,ice_cold_static,ice_blood_static,ice_poison_static"
		kill_when_finished="0"
		steps_per_frame="12"
		clean_stains="1"
		is_circle="1"
		radius="12" 
		loop="1" >
    </MagicConvertMaterialComponent>

    <MagicConvertMaterialComponent
		_tags="enabled_in_hand,enabled_in_world,item_identified"
		kill_when_finished="0"
		extinguish_fire="1"
		is_circle="1"
		loop="1"
		radius="24" >
    </MagicConvertMaterialComponent>

	<Base file="data/entities/base_torch_particle.xml" >

		<ParticleEmitterComponent 
		_tags="enabled_in_hand,item_identified"
		count_min="1"
		x_pos_offset_min="-3"
		x_pos_offset_max="2" 
		lifetime_max="0.5"
		emitted_material_name="ice">
		</ParticleEmitterComponent>

		<ParticleEmitterComponent 
		_tags="enabled_in_hand,item_identified"
		count_min="1"
		color="ff50e7f0"
		x_pos_offset_min="-3"
		x_pos_offset_max="2" 
		lifetime_max="0.6"
		emitted_material_name="spark_blue">
		</ParticleEmitterComponent>

		<ParticleEmitterComponent 
		_tags="enabled_in_hand,item_identified"
		count_min="1"
		x_pos_offset_min="-3"
		x_pos_offset_max="2" 
		lifetime_max="0.7"
		emitted_material_name="plasma_fading">
		</ParticleEmitterComponent>

		</Base>

    <ParticleEmitterComponent 
		_tags="enabled_in_hand,item_identified"
		emitted_material_name="plasma_fading"
		offset.x="0"
		offset.y="0"
		x_pos_offset_min="-2"
		x_pos_offset_max="2"
		y_pos_offset_min="2"
		y_pos_offset_max="-2"
		x_vel_min="-13"
		x_vel_max="13"
		y_vel_min="-42"
		y_vel_max="-28"
		count_min="10"
		count_max="25"
		gravity.y="0"
		lifetime_min="0.1"
		lifetime_max="0.2"
		create_real_particles="0"
		emit_cosmetic_particles="1"
		emission_interval_min_frames="2"
		emission_interval_max_frames="3"
		is_emitting="1" >
	</ParticleEmitterComponent>

	<ParticleEmitterComponent 
		_tags="enabled_in_hand,item_identified"
		emitted_material_name="spark_blue"
		offset.x="0"
		offset.y="0"
		x_pos_offset_min="-2"
		x_pos_offset_max="2"
		y_pos_offset_min="2"
		y_pos_offset_max="-2"
		x_vel_min="-11"
		x_vel_max="11"
		y_vel_min="-36"
		y_vel_max="-24"
		count_min="2"
		count_max="5"
		gravity.y="0"
		lifetime_min="0.2"
		lifetime_max="0.3"
		create_real_particles="0"
		emit_cosmetic_particles="1"
		emission_interval_min_frames="2"
		emission_interval_max_frames="3"
		is_emitting="1" >
	</ParticleEmitterComponent>

	<LightComponent 
		_tags="enabled_in_hand,item_identified"
		_enabled="1" 
		radius="130"
		fade_out_time="1.5" 
		r="240"
		g="180"
		b="120" >
	</LightComponent>

	<LightComponent 
		_tags="enabled_in_hand,item_identified"
		_enabled="1" 
		radius="16"
		fade_out_time="1.5" 
		r="255"
		g="255"
		b="255" >
	</LightComponent>

    <SpriteComponent 
	    _tags="enabled_in_hand"
        alpha="1"
        image_file="data/particles/torch_fog_of_war_hole.xml"
        smooth_filtering="1"
        fog_of_war_hole="1"
        has_special_scale="1"
        special_scale_x="10"
        special_scale_y="10" >
    </SpriteComponent>

    <AudioComponent
	    _tags="enabled_in_hand"
		file="data/audio/Desktop/projectiles.bank"
		event_root="player_projectiles/torch"
		set_latest_event_position="1" >
	</AudioComponent>

	<AudioLoopComponent
	    _tags="enabled_in_hand"
		file="data/audio/Desktop/projectiles.bank"
		event_name="player_projectiles/torch/loop"
		auto_play_if_enabled="1"
		play_on_component_enable="1" >
	</AudioLoopComponent>
    
</Entity>