<Entity tags="energy_shield">
    
    <Base file="data/entities/misc/custom_cards/energy_shield.xml" > 

        <SpriteComponent 
            image_file="data/ui_gfx/gun_actions/deep_end/energy_shield_sector.png" >
        </SpriteComponent>

        <ItemActionComponent 
            _tags="enabled_in_world"
            action_id="ENERGY_SHIELD_SECTOR" >
        </ItemActionComponent>

        <InheritTransformComponent
            use_root_parent="1"
            always_use_immediate_parent_rotation="1"
            ><Transform 
                position.x="0" 
                position.y="-4"
            ></Transform>
        </InheritTransformComponent>

        <EnergyShieldComponent 
            max_energy="1.1"
            sector_degrees="170"
            radius="18.0" >
        </EnergyShieldComponent>

        <ParticleEmitterComponent
            area_circle_sector_degrees="170"
            velocity_always_away_from_center="-40"
            area_circle_radius.min="15"
            area_circle_radius.max="18" >
        </ParticleEmitterComponent>

        <ParticleEmitterComponent
            area_circle_sector_degrees="170"
            area_circle_radius.min="18"
            area_circle_radius.max="18" >
        </ParticleEmitterComponent>

        <ParticleEmitterComponent
            area_circle_sector_degrees="170"
            area_circle_radius.min="18"
            area_circle_radius.max="18" >
        </ParticleEmitterComponent>

    </Base>

