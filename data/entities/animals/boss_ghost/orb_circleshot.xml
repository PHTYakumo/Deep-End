<Entity name="$projectile_default" tags="teleportable_NOT" >

	<VelocityComponent
		gravity_y="0"
		air_friction="0"
		mass="0"
		affect_physics_bodies="1" >
	</VelocityComponent>

	<AudioComponent
		file="data/audio/Desktop/projectiles.bank"
		audio_physics_material="projectile"
		event_root="projectiles/hit" >
	</AudioComponent>

	<ProjectileComponent 
		_enabled="1" 
		lob_min="0.8"
		lob_max="1.0"
		speed_min="150"
		speed_max="150"
		die_on_low_velocity="0"
		on_death_explode="1"
		on_death_gfx_leave_sprite="0" 
		on_lifetime_out_explode="1"
		explosion_dont_damage_shooter="1"
		damage="0"
		on_collision_die="1"
		collide_with_world="0"
		collide_with_tag="player_unit"
		lifetime="150" >
		<damage_by_type
			holy="0.2"
			healing="0.04"
			>
		</damage_by_type>
		<config_explosion
			never_cache="1" 
			camera_shake="0" 
			explosion_radius="9" 
			explosion_sprite="data/particles/explosion_012_poof.xml" 
			explosion_sprite_lifetime="0.0"
			explosion_sprite_additive="1"
			explosion_sprite_emissive="1"
			create_cell_probability="0" 
			create_cell_material="" 
			ray_energy="5000"
			hole_destroy_liquid="1" 
			hole_enabled="0" 
			hole_image="data/temp/explosion_hole.png" 
			particle_effect="0" 
			damage_mortals="0"
			physics_explosion_power.max="0.2"
			physics_explosion_power.max="0.3" 
			physics_throw_enabled="1" 
			shake_vegetation="1" 
			sparks_enabled="0" 
			sparks_count_max="0" 
			sparks_count_min="0"
			light_fade_time="0.8" 
			light_r="10"
			light_g="60"
			light_b="10"
			stains_enabled="0" 
			stains_image="data/temp/explosion_stain.png" >
		</config_explosion>
	</ProjectileComponent>

	<HitEffectComponent 
        effect_hit="LOAD_UNIQUE_CHILD_ENTITY"
        value_string="data/entities/misc/effect_no_heal_de_short.xml" >
    </HitEffectComponent >

	<SpriteComponent 
		_enabled="1" 
		alpha="1" 
		image_file="data/entities/animals/boss_ghost/skull.xml" 
		has_special_scale="1"
	  	special_scale_x="1.25"
	  	special_scale_y="1.25"
		next_rect_animation="" 
		offset_x="0" 
		offset_y="0" 
		rect_animation="stand" 
		update_transform_rotation="1"
		alpha="0.6"
		additive="1"
		emissive="1"
		>
	</SpriteComponent>

	<!-- FX -->
	<ParticleEmitterComponent 
		emitted_material_name="fire_blue"
		emit_cosmetic_particles="1"
		gravity.y="0"
		lifetime_min="2"
		lifetime_max="6"
		count_min="1"
		count_max="1"
		render_on_grid="1"
		fade_based_on_lifetime="1"
		cosmetic_force_create="0"
		airflow_force="0.3"
		airflow_time="1.01"
		airflow_scale="0.05"
		emission_interval_min_frames="4"
		emission_interval_max_frames="12"
		emit_cosmetic_particles="1"
		is_emitting="1" >
	</ParticleEmitterComponent>

	<SpriteParticleEmitterComponent
		sprite_file="data/particles/spark_glitter.xml"
		emission_interval_min_frames="4"
		emission_interval_max_frames="16"
		additive="1"
		emissive="1"
		randomize_lifetime.min="0.5"
		randomize_lifetime.max="2.0"
		entity_velocity_multiplier="0.75"
		randomize_velocity.min_x="-4"
		randomize_velocity.max_x="4"
		randomize_velocity.min_y="-4"
		randomize_velocity.max_y="4"
		randomize_position.min_x="-4"
		randomize_position.max_x="4"
		randomize_position.min_y="-4"
		randomize_position.max_y="4"
		>
	</SpriteParticleEmitterComponent>
	
	<!--
	<AudioComponent
		file="data/audio/Desktop/projectiles.bank"
		event_root="projectiles/magic" >
	</AudioComponent>
	<LightComponent 
		_enabled="1" 
		radius="50" 
		r="255"
		g="50"
		b="255">
	</LightComponent>
	-->

	<LuaComponent
		execute_every_n_frame="1"
		script_source_file="data/entities/animals/boss_ghost/orb_circleshot.lua" >
	</LuaComponent>
	
	<VariableStorageComponent
		name="projectile_file"
		value_string="data/entities/animals/boss_ghost/orb_circleshot.xml"
		>
	</VariableStorageComponent>
</Entity>