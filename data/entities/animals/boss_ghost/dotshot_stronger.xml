<Entity name="$projectile_default" tags="resist_repulsion,projectile_heal" >

	<Base file="data/entities/base_projectile.xml" >
		<VelocityComponent
			gravity_y="0"
			air_friction="-1.8"
			mass="0.05"
			>
		</VelocityComponent> 
	</Base>

	<HomingComponent
		target_tag="player_unit"
		homing_targeting_coeff="9"
		detect_distance="350"
		homing_velocity_multiplier="1.0"
		>
	</HomingComponent>

	<ProjectileComponent 
		_enabled="1" 
		lob_min="0.8"
		lob_max="1.0"
		speed_min="20"
		speed_max="20"
		die_on_low_velocity="0"
		on_death_explode="1"
		on_death_gfx_leave_sprite="0" 
		on_lifetime_out_explode="1"
		explosion_dont_damage_shooter="1"
		damage="0.56"
		on_collision_die="1"
		collide_with_world="0"
		collide_with_tag="player_unit"
		lifetime="75" 
		knockback_force="3.0"
		><damage_by_type
			holy="0.6"
			>
		</damage_by_type>
		<config_explosion
			never_cache="1" 
			camera_shake="0" 
			explosion_radius="10" 
			explosion_sprite="data/particles/explosion_016_plasma_pink.xml" 
			explosion_sprite_lifetime="0.0" 
			create_cell_probability="0" 
			create_cell_material="" 
			ray_energy="5000"
			hole_destroy_liquid="1" 
			hole_enabled="0" 
			hole_image="data/temp/explosion_hole.png"
			explosion_sprite_emissive="1"
			explosion_sprite_additive="1"
			particle_effect="0" 
			damage_mortals="0"
			physics_explosion_power.min="0.24" 
			physics_explosion_power.max="0.34"
			physics_throw_enabled="1" 
			shake_vegetation="1" 
			sparks_enabled="0" 
			sparks_count_max="0" 
			sparks_count_min="0"
			light_fade_time="0.8" 
			light_r="60"
			light_g="10"
			light_b="10"
			stains_enabled="0" 
			stains_image="data/temp/explosion_stain.png"
			audio_enabled="0" >
		</config_explosion>
	</ProjectileComponent>

	<HitEffectComponent 
        effect_hit="LOAD_UNIQUE_CHILD_ENTITY"
        value_string="data/entities/misc/effect_no_heal_de_short.xml" >
    </HitEffectComponent >
	
	<SpriteComponent 
		_enabled="1" 
		alpha="1" 
		image_file="data/particles/skullface_teal.xml" 
		has_special_scale="0"
	  	special_scale_x="0.75"
	  	special_scale_y="0.75"
		next_rect_animation="" 
		offset_x="0" 
		offset_y="0" 
		rect_animation="stand" 
		update_transform_rotation="0"
		additive="1"
		emissive="1"
		>
	</SpriteComponent>

	<SpriteParticleEmitterComponent
		sprite_file="data/particles/skullface_teal.xml" 
		delay="0"
		lifetime="0.5"
		additive="1"
		color.r="1" color.g="1" color.b="1" color.a="0.5"
		color_change.r="0" color_change.g="0" color_change.b="0" color_change.a="-2.5"
		velocity.x="0" velocity.y="0"
		gravity.x="0" gravity.y="0"
		velocity_slowdown="0"
		rotation="0"
		angular_velocity="0"
		use_velocity_as_rotation="0"
		scale.x="1" scale.y="1"
		scale_velocity.x="0" scale_velocity.y="0"
		emission_interval_min_frames="2"
		emission_interval_max_frames="2"
		randomize_rotation.min="0"
		randomize_rotation.max="0"
		count_min="1" count_max="1"
		is_emitting="1"
		render_back="1"
		>
	</SpriteParticleEmitterComponent>
	
	<LightComponent 
		_enabled="1" 
		radius="150" 
		r="90"
		g="30"
		b="30">
	</LightComponent>
	
	<AudioComponent
		file="data/audio/Desktop/projectiles.bank"
		event_root="projectiles/orb_b" >
	</AudioComponent>
	
	<VariableStorageComponent
		name="projectile_file"
		value_string="data/entities/animals/boss_ghost/dotshot_stronger.xml"
		>
	</VariableStorageComponent>
	
	<HitEffectComponent 
        effect_hit="LOAD_CHILD_ENTITY"
        value_string="data/entities/misc/curse_stronger_init.xml" >
	</HitEffectComponent >
</Entity>