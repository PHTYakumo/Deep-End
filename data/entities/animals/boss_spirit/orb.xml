<Entity name="$projectile_default" tags="resist_repulsion,projectile_heal,projectile_boss_spirit" >

	<Base file="data/entities/base_projectile.xml" >
		<VelocityComponent
    		gravity_y="0"
        air_friction="0.00"
        mass="0.004"
			>
    	</VelocityComponent> 
	</Base>

	<HomingComponent
		target_tag="player_unit"
		just_rotate_towards_target="1"
		max_turn_rate="0.1"
	>
	</HomingComponent>

  <ProjectileComponent 
    _enabled="1" 
	lob_min="0.8"
  	lob_max="1.0"
  	speed_min="85"
  	speed_max="85"
    die_on_low_velocity="0"
    on_death_explode="1"
    on_death_gfx_leave_sprite="0" 
    on_lifetime_out_explode="1"
	explosion_dont_damage_shooter="1"
    damage="0.02"
    on_collision_die="0"
    collide_with_tag="player_unit"
    collide_with_world="0"
    lifetime="180" 
	knockback_force="2.0"
	bounces_left="10"
	bounce_always="1"
	><damage_by_type 
  	healing="-0.004" 
	holy="0.002"
  	ice="0.002"
  	curse="0.002"
  	fire="0.002"
  	></damage_by_type>
    <config_explosion
      never_cache="1" 
      camera_shake="0.5" 
      explosion_radius="18" 
      explosion_sprite="data/particles/explosion_016_plasma.xml" 
      explosion_sprite_lifetime="0.1" 
      create_cell_probability="1" 
      create_cell_material="plasma_fading"
	  explosion_sprite_emissive="1"
	  explosion_sprite_additive="1"
	  ray_energy="100000"
      hole_destroy_liquid="1" 
      hole_enabled="1" 
	  damage="0.2"
      hole_image="data/temp/explosion_hole.png" 
      particle_effect="0" 
      damage_mortals="1"
	  physics_throw_enabled="1"
      shake_vegetation="1"  
      sparks_enabled="1" 
	  spark_material="spark_blue"
      sparks_count_max="16" 
      sparks_count_min="4"
      light_fade_time="1.2" 
	  light_r="45"
	  light_g="200"
      light_b="250"
      stains_enabled="1" 
      stains_image="data/temp/explosion_stain.png" >
    </config_explosion>
  </ProjectileComponent>
  
  <SpriteComponent 
    _enabled="1" 
    alpha="0.7" 
    image_file="data/projectiles_gfx/orb_blue_big.xml" 
    next_rect_animation="" 
    offset_x="0" 
    offset_y="0" 
    has_special_scale="1"
	  special_scale_x="0.12"
	  special_scale_y="0.12"
    rect_animation="fireball" 
	emissive="1"
    additive="1"
     
	update_transform_rotation="0"
	>
  </SpriteComponent>
  
  <LightComponent 
    _enabled="1" 
    radius="150" 
    r="40"
    g="185"
    b="250">
  </LightComponent>

	<AudioComponent
		file="data/audio/Desktop/projectiles.bank"
		event_root="player_projectiles/black_hole"
		>
	</AudioComponent>
	
	<AudioLoopComponent
		file="data/audio/Desktop/projectiles.bank"
		event_name="projectiles/magic_orb/loop"
		auto_play="1">
	</AudioLoopComponent>
	
	<VariableStorageComponent
		name="projectile_file"
		value_string="data/entities/animals/boss_spirit/orb.xml"
		>
	</VariableStorageComponent>
	
	<LuaComponent
		execute_every_n_frame="175"
		script_source_file="data/entities/animals/boss_spirit/orb_effect.lua"
		remove_after_executed="1"
		>
	</LuaComponent>

  <LuaComponent
		_enabled="1" 
		remove_after_executed="0"
		script_source_file="data/entities/animals/boss_spirit/orb_rnd/orb_rotation.lua" 
		execute_every_n_frame="1"
	></LuaComponent>
	
  <LuaComponent
		remove_after_executed="1"
		script_source_file="data/entities/animals/boss_spirit/orb_rnd/orb_start.lua" 
		execute_on_added="1"
	></LuaComponent>

	<ParticleEmitterComponent 
		emitted_material_name="spark_blue"
		gravity.y="0"
		lifetime_min="0.3"
		lifetime_max="0.8"
		count_min="9"
		count_max="18"
		render_on_grid="1"
		fade_based_on_lifetime="1"
		area_circle_radius.min="1"
		area_circle_radius.max="2"
		cosmetic_force_create="0"
		airflow_force="1.5"
		airflow_time="1.9"
		airflow_scale="0.15"
		emission_interval_min_frames="1"
		emission_interval_max_frames="1"
		emit_cosmetic_particles="1"
		draw_as_long="1"
		x_vel_min="-1"
		x_vel_max="1"
		y_vel_min="-1"
		y_vel_max="1"
		is_emitting="1" 
		velocity_always_away_from_center="160"
		>
	</ParticleEmitterComponent>

	<ParticleEmitterComponent 
		emitted_material_name="spark_blue"
		gravity.y="0"
		lifetime_min="0.4"
		lifetime_max="0.7"
		count_min="9"
		count_max="18"
		render_on_grid="1"
		fade_based_on_lifetime="1"
		area_circle_radius.min="1"
		area_circle_radius.max="2"
		cosmetic_force_create="0"
		airflow_force="1.5"
		airflow_time="1.9"
		airflow_scale="0.15"
		emission_interval_min_frames="1"
		emission_interval_max_frames="1"
		emit_cosmetic_particles="1"
		draw_as_long="1"
		x_vel_min="-1"
		x_vel_max="1"
		y_vel_min="-1"
		y_vel_max="1"
		is_emitting="1" 
		velocity_always_away_from_center="280"
		>
	</ParticleEmitterComponent>
</Entity>