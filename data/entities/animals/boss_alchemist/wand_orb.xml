<Entity 
  name="$projectile_default" 
  tags="boss_alchemist"
   >

	<Base file="data/entities/base_projectile.xml" >
		<VelocityComponent
    		gravity_y="0"
        air_friction="0.0"
        mass="0.055"
			>
    	</VelocityComponent> 
	</Base>

  <ProjectileComponent 
    _enabled="1" 
	  lob_min="0.8"
  	lob_max="1.0"
  	speed_min="750"
  	speed_max="750"
    die_on_low_velocity="0"
    on_death_explode="1"
    on_death_gfx_leave_sprite="0" 
    on_lifetime_out_explode="1"
	  explosion_dont_damage_shooter="1"
    damage="1.2"
    on_collision_die="0"
    lifetime="120" 
	  knockback_force="1.5"
	  bounces_left="20"
	  bounce_always="1"
	>
    <config_explosion
      never_cache="1" 
      camera_shake="0.5" 
      explosion_radius="1" 
      explosion_sprite="data/particles/explosion_032_slimeburst_yellow.xml" 
      explosion_sprite_lifetime="0.0" 
      create_cell_probability="1" 
      create_cell_material="plasma_fading"
	    explosion_sprite_emissive="1"
	    explosion_sprite_additive="1"
	    ray_energy="10000"
      hole_destroy_liquid="1" 
      hole_enabled="1" 
	    damage = "0.1"
      hole_image="data/temp/explosion_hole.png" 
      particle_effect="0" 
      damage_mortals="1"
	    physics_throw_enabled="0"
      shake_vegetation="1"  
      sparks_enabled="1" 
	    spark_material="spark_yellow"
      sparks_count_max="16" 
      sparks_count_min="12"
      light_fade_time="1.2" 
	    light_r="255"
	    light_g="196"
      light_b="0"
      stains_enabled="1" 
      stains_image="data/temp/explosion_stain.png" >
    </config_explosion>
  </ProjectileComponent>
  
  <SpriteComponent 
    _enabled="1" 
    alpha="0.875" 
    image_file="data/projectiles_gfx/orb_yellow.xml" 
    next_rect_animation="" 
    rect_animation="fireball"
    has_special_scale="1"
	  special_scale_x="1.5"
	  special_scale_y="1.5" 
	  emissive="1"
    additive="1"
	  update_transform_rotation="1"
	>
  </SpriteComponent>

  <SpriteComponent 
    _enabled="1" 
    alpha="0.125" 
    image_file="data/projectiles_gfx/orb_red.xml" 
    next_rect_animation="" 
    rect_animation="fireball"
    has_special_scale="1"
	  special_scale_x="1.5"
	  special_scale_y="1.5" 
	  emissive="1"
    additive="1"
	  update_transform_rotation="1"
	>
  </SpriteComponent>
  
  <LightComponent 
    _enabled="1" 
    radius="150" 
    r="255"
    g="196"
    b="0">
  </LightComponent>
  
  <SpriteParticleEmitterComponent
    sprite_file="data/particles/spark_electric.xml"
    delay="0"
    lifetime="0"
    color.r="1" color.g="0.75" color.b="0" color.a="1"
    color_change.r="0" color_change.g="0" color_change.b="0" color_change.a="0"
    velocity.x="0" velocity.y="0"
    gravity.x="0" gravity.y="0"
    velocity_slowdown="0"
    rotation="0"
    angular_velocity="0"
    use_velocity_as_rotation="0"
    scale.x="1" scale.y="1"
    scale_velocity.x="0" scale_velocity.y="0"
    emission_interval_min_frames="3"
    emission_interval_max_frames="3"
    count_min="1" count_max="2"
    randomize_rotation.min="-3.1416"
    randomize_rotation.max="3.1416"
    randomize_position.min_x="-6"
    randomize_position.max_x="6"
    randomize_position.min_y="-6"
    randomize_position.max_y="6"
    >
  </SpriteParticleEmitterComponent>

  <HitEffectComponent 
        effect_hit="LOAD_UNIQUE_CHILD_ENTITY"
        value_string="data/entities/misc/effect_de_woolgather_short.xml" >
	</HitEffectComponent >
  
	<LuaComponent
		execute_on_added="1"
		script_source_file="data/entities/animals/boss_alchemist/init.lua"
		remove_after_executed="1"
		>
	</LuaComponent>
	
	<LuaComponent
		execute_every_n_frame="21"
		script_source_file="data/entities/animals/boss_alchemist/create_wand.lua"
		>
	</LuaComponent>

  <LuaComponent
		execute_every_n_frame="1"
		script_source_file="data/entities/animals/boss_alchemist/wand_orb_rotate.lua"
		>
	</LuaComponent>

  <LuaComponent
		execute_every_n_frame="21"
		script_source_file="data/entities/animals/boss_alchemist/wand_orb_twist.lua"
		>
	</LuaComponent>
	
	<VariableStorageComponent
		name="type"
		value_string=""
		>
	</VariableStorageComponent>

	<AudioComponent
		file="data/audio/Desktop/projectiles.bank"
		event_root="projectiles/orb_dark" >
	</AudioComponent>
	
	<AudioLoopComponent
		file="data/audio/Desktop/projectiles.bank"
		event_name="projectiles/magic_orb/loop"
		auto_play="1">
	</AudioLoopComponent>
	
	<VariableStorageComponent
		name="projectile_file"
		value_string="data/entities/animals/boss_alchemist/wand_orb.xml"
		>
	</VariableStorageComponent>
</Entity>