<Entity 
  name="$projectile_default" tags="projectile,boss_alchemist"
   >

	<Base file="data/entities/base_projectile.xml" >
		<VelocityComponent
      gravity_y="0"
			air_friction="-1.2"
			mass="0.07"
      terminal_velocity="1437"
			>
		</VelocityComponent>
	</Base>

  <ProjectileComponent 
    _enabled="1" 
    lob_min="0.2"
    lob_max="0.5"
    speed_min="80"
    speed_max="90"
    friction="0"
    direction_random_rad="0.05"
    on_death_explode="1"
    on_death_gfx_leave_sprite="0" 
    on_lifetime_out_explode="1"
    explosion_dont_damage_shooter="1" 
    on_collision_die="1"
    dont_collide_with_tag="enemy"
    lifetime="180"
    damage="0.4"
    velocity_sets_scale="1"
    lifetime_randomness="3"
    ragdoll_force_multiplier="0.04"
    hit_particle_force_multiplier="5.5"
    camera_shake_when_shot="5.0"
    bounces_left="12"
    shoot_light_flash_radius="20"
	  muzzle_flash_file="data/entities/particles/muzzle_flashes/muzzle_flash_launcher_large.xml"
	  knockback_force="2.0"
	><damage_by_type
		poison="0.4"
		>
	</damage_by_type>
    <config_explosion
      never_cache="0" 
      camera_shake="6" 
      explosion_radius="8"
      explosion_sprite="" 
      load_this_entity="data/entities/particles/particle_explosion/main_bluesmoke_tiny.xml"
      explosion_sprite_lifetime="0" 
      create_cell_probability="0" 
      hole_destroy_liquid="0" 
      hole_enabled="1" 
      ray_energy="25000"
      damage="0.12"
      particle_effect="0"
      damage_mortals="1"
	  physics_explosion_power.min="0.15"
      physics_explosion_power.max="0.35" 
      shake_vegetation="1"
      spark_material="spark_blue" 
      sparks_count_min="1" 
      sparks_count_max="3" 
      sparks_enabled="0" 
      stains_enabled="0"
      stains_radius="6"
      audio_event_name="explosions/magic_grenade_mid" >
    </config_explosion>
  </ProjectileComponent>

  <SineWaveComponent
    _enabled="1" 
    sinewave_freq="1.0"
    sinewave_m="0.4"
    lifetime="-1"
	 >
  </SineWaveComponent>
  
  <SpriteComponent 
    _enabled="1" 
    alpha="1" 
    image_file="data/projectiles_gfx/iceball.xml" 
    has_special_scale="1"
	  special_scale_x="0.6"
	  special_scale_y="1.2"
    next_rect_animation="" 
    offset_x="0" 
    offset_y="0" 
    rect_animation="" 
     >
  </SpriteComponent>

  <LightComponent 
    _enabled="1" 
    radius="20" >
  </LightComponent>

  <AudioComponent
      file="data/audio/Desktop/projectiles.bank"
      event_root="projectiles/bullet_launcher"
	  >
  </AudioComponent>
  
  <VariableStorageComponent
		name="projectile_file"
		value_string="data/entities/animals/boss_alchemist/grenade_blue.xml"
		>
	</VariableStorageComponent>

  
</Entity>



