      shake_vegetation="1" 
      sparks_count_max="5" 
      sparks_count_min="2" 
      sparks_enabled="0" 
      stains_enabled="0" 
      stains_radius="15"
      audio_event_name="explosions/tnt" >
    </config_explosion>
