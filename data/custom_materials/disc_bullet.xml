<Entity name="$projectile_default" tags="projectile_player,disc_bullet" >

	<Base file="data/entities/base_projectile.xml" >
		<VelocityComponent
			gravity_y="-200"
			air_friction="0.8"
			mass="0.05"
			>
		</VelocityComponent>
	</Base>

  <HomingComponent
		target_tag="mortal"
		homing_targeting_coeff="9"
		detect_distance="27"
    just_rotate_towards_target="1"
		homing_velocity_multiplier="0.2"
		>
	</HomingComponent>

  <ProjectileComponent 
    _enabled="1" 
    lob_min="0.5"
    lob_max="0.7"
    speed_min="350"
    speed_max="450"
    friction="1"
    direction_random_rad="0.01"
    on_death_explode="0"
    on_death_gfx_leave_sprite="0" 
    on_lifetime_out_explode="0"
    explosion_dont_damage_shooter="1"
    on_collision_die="0"
    on_collision_remove_projectile="0"
    dont_collide_with_tag="boss_ghost_helper"
    lifetime="120"
    damage="0"
    damage_scaled_by_speed="0"
    lifetime_randomness="60"
    ragdoll_force_multiplier="0"
    hit_particle_force_multiplier="0.1"
    create_shell_casing="0"
    muzzle_flash_file="data/entities/particles/muzzle_flashes/muzzle_flash_medium.xml"
    shoot_light_flash_r="255"
    shoot_light_flash_g="240"
    shoot_light_flash_b="30"
    shoot_light_flash_radius="64"
    die_on_low_velocity="0"
    bounces_left="10"
    bounce_at_any_angle="1"
    bounce_energy="1.3"
    collide_with_shooter_frames="6"
    friendly_fire="1"
    velocity_sets_rotation="1"
    velocity_updates_animation="1"
    velocity_sets_scale="0"
    ragdoll_fx_on_collision="BLOOD_EXPLOSION"
	  knockback_force="13.0"
    physics_impulse_coeff="1500"
    damage_every_x_frames="30"
    >
	<damage_by_type
		slice="0.02"
		>
	</damage_by_type>
    <config_explosion>
    </config_explosion>
  </ProjectileComponent>
  
  <SpriteComponent 
    _enabled="1" 
    alpha="1" 
    image_file="data/projectiles_gfx/disc_bullet.xml"
    has_special_scale="1"
	  special_scale_x="0.7"
	  special_scale_y="0.7" 
    next_rect_animation=""
    rect_animation="" 
     >
  </SpriteComponent>
  
  <SpriteParticleEmitterComponent
    sprite_file="data/particles/discbullet_trail.xml"
    delay="0"
    lifetime="1"
	  additive="1"
    color.r="1" color.g="1" color.b="1" color.a="1"
    color_change.r="0" color_change.g="0" color_change.b="0" color_change.a="-4"
    velocity.x="0" velocity.y="0"
    gravity.x="0" gravity.y="10"
    velocity_slowdown="0"
    rotation="0"
    angular_velocity="0"
    use_velocity_as_rotation="0"
    scale.x="0.8" scale.y="0.8"
    scale_velocity.x="0" scale_velocity.y="0"
    emission_interval_min_frames="15"
    emission_interval_max_frames="15"
    count_min="1" count_max="1"
	  is_emitting="1"
	  render_back="1"
    >
  </SpriteParticleEmitterComponent>

    <AudioComponent
        file="data/audio/Desktop/projectiles.bank"
        event_root="player_projectiles/bullet_disc">
    </AudioComponent>
  
    <AudioLoopComponent
        file="data/audio/Desktop/projectiles.bank"
        event_name="player_projectiles/bullet_disc/loop"
        set_speed_parameter="1"
        auto_play="1">
    </AudioLoopComponent>

    <HitEffectComponent 
        effect_hit="LOAD_UNIQUE_CHILD_ENTITY"
        value_string="data/entities/misc/effect_de_light_headedness_short.xml" >
	</HitEffectComponent >
    
	<VariableStorageComponent
		name="projectile_file"
		value_string="data/custom_materials/disc_bullet.xml"
		>
	</VariableStorageComponent>

</Entity>

