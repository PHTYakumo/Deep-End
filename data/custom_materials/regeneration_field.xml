<Entity name="$projectile_default" tags="projectile_heal">
	<GameAreaEffectComponent
  		radius="32" >
	</GameAreaEffectComponent>

	<AreaDamageComponent
		aabb_min.x="-32" 
		aabb_min.y="-32" 
		aabb_max.x="32" 
		aabb_max.y="32" 
		damage_per_frame="-0.12"
		update_every_n_frame="6"
		entities_with_tag="player_unit"
		death_cause="?"
		damage_type="DAMAGE_HEALING"
		>
	</AreaDamageComponent>

	<HomingComponent
		target_tag="prey"
		homing_targeting_coeff="15"
		detect_distance="200"
		homing_velocity_multiplier="0.99"
		>
	</HomingComponent>

	<Base file="data/entities/projectiles/deck/base_field.xml">
		<SpriteComponent 
			has_special_scale="1"
			special_scale_x="0.6"
			special_scale_y="0.6"
			image_file="data/projectiles_gfx/blast_regeneration.xml" >
		</SpriteComponent>
		
		<LifetimeComponent
			lifetime="60" >
		</LifetimeComponent>

		<SpriteParticleEmitterComponent
			sprite_file="data/particles/heal.xml"
			delay="0"
			lifetime="0"
			emission_interval_min_frames="15"
			emission_interval_max_frames="30"
			color.r="1" color.g="1" color.b="1" color.a="1"
			color_change.r="0" color_change.g="0" color_change.b="0" color_change.a="-1" >
		</SpriteParticleEmitterComponent>

		<ProjectileComponent 
			damage_game_effect_entities="data/entities/misc/effect_regeneration.xml,"
			penetrate_entities="0"
			friendly_fire="1"
			damage_every_x_frames="6"
			collide_with_shooter_frames="0" >
			<damage_by_type 
				healing="-0.12"
				>
			</damage_by_type>
			<config_explosion
				explosion_sprite="data/particles/blast_out_regeneration.xml" >
			</config_explosion>
		</ProjectileComponent>
		
		<AudioLoopComponent
			file="data/audio/Desktop/projectiles.bank"
			event_name="player_projectiles/field_regeneration/loop"
			auto_play="1">
		</AudioLoopComponent>
	</Base>
</Entity>

